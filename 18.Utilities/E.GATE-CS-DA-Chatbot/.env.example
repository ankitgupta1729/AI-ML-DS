# ----------------------------------------------------------------------------
# Copy this file to `.env` and fill in your values.  NEVER commit `.env`.
# ----------------------------------------------------------------------------

# Required: your OpenAI API key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your-key-here

# --- Models -----------------------------------------------------------------
# Chat model used to generate answers. gpt-4o-mini is fast & cheap; use
# gpt-4o or gpt-4.1 for the highest quality.
CHAT_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
TEMPERATURE=0.2
MAX_TOKENS=1024

# Optional: point at any OpenAI-compatible endpoint for a local / offline model
# (Ollama, LM Studio, vLLM, etc.). Leave blank to use OpenAI.
# OPENAI_BASE_URL=http://localhost:11434/v1

# --- Retrieval --------------------------------------------------------------
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
RETRIEVER_K=5
# 0–1; chunks scoring below this are treated as irrelevant by the guardrail.
RELEVANCE_THRESHOLD=0.25
# Optional cross-encoder reranking for sharper citations (needs `flashrank`).
# RERANK=true
# RERANK_TOP_N=20

# --- Storage (relative paths are fine) --------------------------------------
# DATA_DIR=data
# VECTOR_DIR=storage/chroma
COLLECTION_NAME=gate_cs_da

# --- Application database (conversations, messages, feedback, RLHF data) -----
# SQLite by default (storage/app.db). For production use Postgres, e.g.:
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/gateoverflow
# DATABASE_URL=sqlite:///storage/app.db

# --- API server -------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
