# Base URL of the FastAPI backend, used at BUILD time for production bundles.
# Leave unset for local dev — Vite proxies /api → http://localhost:8000.
# Example for production: VITE_API_BASE=https://api.your-domain.com
# VITE_API_BASE=https://api.your-domain.com

# Optional: override the dev proxy target (defaults to http://localhost:8000)
# VITE_API_PROXY=http://localhost:8000
