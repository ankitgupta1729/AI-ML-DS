---
import { SITE, NAV, CATEGORIES } from "../consts";
import SocialLinks from "./SocialLinks.astro";

const year = new Date().getFullYear();
const topCats = CATEGORIES.slice(0, 6);
---

<footer class="mt-24 border-t border-gray-200/70 bg-white/50 dark:border-white/10 dark:bg-white/[0.02]">
  <div class="mx-auto grid max-w-6xl gap-10 px-4 py-12 sm:px-6 md:grid-cols-4">
    <div class="md:col-span-2">
      <div class="flex items-center gap-2">
        <span class="grid h-9 w-9 place-items-center rounded-xl bg-gradient-to-br from-brand-500 to-pink-500 text-lg font-black text-white">P</span>
        <span class="text-lg font-extrabold text-gray-900 dark:text-white">{SITE.name}</span>
      </div>
      <p class="mt-3 max-w-sm text-sm leading-relaxed text-gray-600 dark:text-gray-400">
        {SITE.description}
      </p>
      <div class="mt-5">
        <SocialLinks />
      </div>
      <button id="install-app" class="mt-4 hidden items-center gap-2 rounded-lg border border-brand-300 px-3 py-2 text-sm font-semibold text-brand-700 transition hover:bg-brand-50 dark:border-brand-500/40 dark:text-brand-300 dark:hover:bg-white/5">
        📲 Install app
      </button>
    </div>

    <div>
      <h3 class="text-xs font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400">Explore</h3>
      <ul class="mt-3 space-y-2 text-sm">
        {NAV.map((n) => (
          <li><a href={n.href} class="text-gray-600 transition hover:text-brand-600 dark:text-gray-400 dark:hover:text-white">{n.name}</a></li>
        ))}
        <li><a href="/doubts" class="text-gray-600 transition hover:text-brand-600 dark:text-gray-400 dark:hover:text-white">Doubts</a></li>
        <li><a href="/pyq" class="text-gray-600 transition hover:text-brand-600 dark:text-gray-400 dark:hover:text-white">Previous-year Qs</a></li>
        <li><a href="/mock-tests" class="text-gray-600 transition hover:text-brand-600 dark:text-gray-400 dark:hover:text-white">Mock Tests</a></li>
        <li><a href="/exam-alerts" class="text-gray-600 transition hover:text-brand-600 dark:text-gray-400 dark:hover:text-white">Exam alerts</a></li>
        <li><a href="/prep" class="text-gray-600 transition hover:text-brand-600 dark:text-gray-400 dark:hover:text-white">Prep tips</a></li>
        <li><a href="/resources" class="text-gray-600 transition hover:text-brand-600 dark:text-gray-400 dark:hover:text-white">Books &amp; lectures</a></li>
        <li><a href="/start-here" class="text-gray-600 transition hover:text-brand-600 dark:text-gray-400 dark:hover:text-white">Start here</a></li>
        <li><a href="/posts" class="text-gray-600 transition hover:text-brand-600 dark:text-gray-400 dark:hover:text-white">Community posts</a></li>
        <li><a href="/categories" class="text-gray-600 transition hover:text-brand-600 dark:text-gray-400 dark:hover:text-white">Topics</a></li>
        <li><a href="/forum" class="text-gray-600 transition hover:text-brand-600 dark:text-gray-400 dark:hover:text-white">Forum</a></li>
        <li><a href="/progress" class="text-gray-600 transition hover:text-brand-600 dark:text-gray-400 dark:hover:text-white">My progress</a></li>
        <li><a href="/practice" class="text-gray-600 transition hover:text-brand-600 dark:text-gray-400 dark:hover:text-white">My practice</a></li>
        <li><a href="/community" class="text-gray-600 transition hover:text-brand-600 dark:text-gray-400 dark:hover:text-white">Community</a></li>
        <li><a href="/feedback" class="text-gray-600 transition hover:text-brand-600 dark:text-gray-400 dark:hover:text-white">Feedback &amp; ideas</a></li>
        <li><a href="/tags" class="text-gray-600 transition hover:text-brand-600 dark:text-gray-400 dark:hover:text-white">Tags</a></li>
        <li><a href="/reading-list" class="text-gray-600 transition hover:text-brand-600 dark:text-gray-400 dark:hover:text-white">Reading list</a></li>
      </ul>
    </div>

    <div>
      <h3 class="text-xs font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400">Topics</h3>
      <ul class="mt-3 space-y-2 text-sm">
        {topCats.map((c) => (
          <li><a href={`/categories/${c.slug}`} class="text-gray-600 transition hover:text-brand-600 dark:text-gray-400 dark:hover:text-white">{c.name}</a></li>
        ))}
      </ul>
    </div>
  </div>

  <div class="border-t border-gray-200/70 dark:border-white/10">
    <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-2 px-4 py-5 text-xs text-gray-500 sm:flex-row sm:px-6 dark:text-gray-400">
      <p>© {year} {SITE.author}. Built with Astro · Free & open. Content under CC BY 4.0.</p>
      <p>Made for curious minds everywhere.</p>
    </div>
  </div>
</footer>
