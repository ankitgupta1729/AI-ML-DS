---
// Problem of the Week — a featured challenge that rotates weekly. Students
// discuss and post solutions in the Doubts community.
const uid = "pw" + Math.random().toString(36).slice(2, 8);
---

<div id={uid} class="not-prose rounded-2xl border border-amber-300/60 bg-gradient-to-br from-amber-50 to-orange-50 p-5 dark:border-amber-500/30 dark:from-amber-900/20 dark:to-orange-900/10">
  <div class="mb-1 flex items-center justify-between">
    <span class="text-xs font-bold uppercase tracking-wide text-amber-700 dark:text-amber-300">⭐ Problem of the Week</span>
    <span data-tag class="rounded-full bg-white/70 px-2 py-0.5 text-xs font-semibold text-amber-700 dark:bg-white/10 dark:text-amber-300"></span>
  </div>
  <h3 data-title class="font-serif text-xl font-bold text-gray-900 dark:text-white"></h3>
  <p data-body class="mt-2 text-sm leading-relaxed text-gray-700 dark:text-gray-200"></p>
  <a href="/doubts" class="mt-3 inline-block rounded-lg bg-amber-600 px-4 py-2 text-sm font-semibold text-white transition hover:bg-amber-700">💬 Post your solution in Doubts</a>
</div>

<script is:inline define:vars={{ uid }}>
  (function () {
    const root = document.getElementById(uid);
    if (!root) return;
    const P = [
      { tag: "Mathematics", title: "The handshake problem", body: "At a party, every person shakes hands with every other person exactly once. If there were 66 handshakes in total, how many people were at the party? Prove your answer." },
      { tag: "Physics", title: "The falling slinky", body: "A slinky is held by its top and allowed to stretch under gravity, then released. What does the bottom of the slinky do in the instant after release — and why?" },
      { tag: "Computer Science", title: "Find the duplicate", body: "You have an array of n+1 integers, each between 1 and n. At least one value repeats. Find a repeated number using O(1) extra space and without modifying the array." },
      { tag: "Logic", title: "The 100 prisoners", body: "100 prisoners, numbered 1–100, must each find their number among 100 boxes (randomly labelled) opening at most 50 boxes. They may strategise beforehand but not communicate after. A strategy gives them a ~31% survival chance — what is it?" },
      { tag: "Probability", title: "Expected coin flips", body: "On average, how many times must you flip a fair coin to first see two heads in a row (HH)? Derive the exact expected value." },
      { tag: "Mathematics", title: "Sum of a chessboard", body: "Place 1 grain on the first square of a chessboard, 2 on the next, 4 on the next, doubling each time. How many grains on the whole board? Express it cleanly." },
      { tag: "Number theory", title: "Always divisible", body: "Prove that n³ − n is divisible by 6 for every integer n." },
      { tag: "Geometry", title: "The ant on a box", body: "An ant is at one corner of a 1×1×2 box and wants to reach the opposite corner, walking only on the surface. What is the shortest path length?" },
    ];
    const week = Math.floor(Date.now() / (7 * 86400000));
    const p = P[week % P.length];
    root.querySelector("[data-tag]").textContent = p.tag;
    root.querySelector("[data-title]").textContent = p.title;
    root.querySelector("[data-body]").textContent = p.body;
  })();
</script>
