---
// Lightweight, backend-free reactions + share row.
// Likes/dislikes are stored per-visitor in localStorage for instant feedback;
// durable, cross-visitor reactions live in the Giscus discussion below.
interface Props {
  title: string;
}
const { title } = Astro.props;
---

<div
  class="my-8 flex flex-col gap-4 rounded-2xl border border-gray-200 bg-white p-4 sm:flex-row sm:items-center sm:justify-between dark:border-white/10 dark:bg-white/[0.03]"
  data-reaction-bar
>
  <div class="flex items-center gap-2">
    <span class="mr-1 text-sm font-medium text-gray-600 dark:text-gray-400">Was this useful?</span>
    <button data-react="like" class="reaction-btn" aria-label="Like">
      👍 <span data-count="like">0</span>
    </button>
    <button data-react="dislike" class="reaction-btn" aria-label="Dislike">
      👎 <span data-count="dislike">0</span>
    </button>
    <button data-react="love" class="reaction-btn" aria-label="Love">
      ❤️ <span data-count="love">0</span>
    </button>
  </div>

  <div class="flex flex-wrap items-center gap-2">
    <span class="mr-1 text-sm font-medium text-gray-600 dark:text-gray-400">Share</span>
    <button data-share="native" class="reaction-btn" aria-label="Share" hidden>📤 Share</button>
    <a data-share="twitter" target="_blank" rel="noopener" class="reaction-btn" aria-label="Share on X">𝕏</a>
    <a data-share="linkedin" target="_blank" rel="noopener" class="reaction-btn" aria-label="Share on LinkedIn">in</a>
    <a data-share="facebook" target="_blank" rel="noopener" class="reaction-btn" aria-label="Share on Facebook">f</a>
    <a data-share="reddit" target="_blank" rel="noopener" class="reaction-btn" aria-label="Share on Reddit">🅡</a>
    <a data-share="hn" target="_blank" rel="noopener" class="reaction-btn" aria-label="Share on Hacker News">Y</a>
    <a data-share="telegram" target="_blank" rel="noopener" class="reaction-btn" aria-label="Share on Telegram">✈</a>
    <a data-share="whatsapp" target="_blank" rel="noopener" class="reaction-btn" aria-label="Share on WhatsApp">✆</a>
    <a data-share="email" class="reaction-btn" aria-label="Share by email">✉</a>
    <button data-share="copy" class="reaction-btn" aria-label="Copy link">🔗</button>
  </div>
</div>

<style>
  .reaction-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    border-radius: 0.6rem;
    border: 1px solid rgb(229 231 235);
    padding: 0.4rem 0.7rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: rgb(55 65 81);
    cursor: pointer;
    transition: all 0.15s ease;
    background: transparent;
  }
  .reaction-btn:hover { border-color: #818cf8; transform: translateY(-1px); }
  .reaction-btn.active { background: #eef2ff; border-color: #6366f1; color: #4338ca; }
  :global(.dark) .reaction-btn { border-color: rgba(255,255,255,0.12); color: rgb(209 213 219); }
  :global(.dark) .reaction-btn.active { background: rgba(99,102,241,0.18); color: #c7d2fe; }
</style>

<script is:inline define:vars={{ title }}>
  (function () {
    const bar = document.querySelector("[data-reaction-bar]");
    if (!bar) return;
    const key = "reactions:" + location.pathname;
    const url = location.href;

    let state = {};
    try { state = JSON.parse(localStorage.getItem(key) || "{}"); } catch (e) {}

    function render() {
      ["like", "dislike", "love"].forEach((k) => {
        const span = bar.querySelector(`[data-count="${k}"]`);
        if (span) span.textContent = state[k]?.count || 0;
        const btn = bar.querySelector(`[data-react="${k}"]`);
        if (btn) btn.classList.toggle("active", !!state[k]?.mine);
      });
    }

    bar.querySelectorAll("[data-react]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const k = btn.getAttribute("data-react");
        state[k] = state[k] || { count: 0, mine: false };
        state[k].mine = !state[k].mine;
        state[k].count += state[k].mine ? 1 : -1;
        if (state[k].count < 0) state[k].count = 0;
        localStorage.setItem(key, JSON.stringify(state));
        render();
      });
    });

    const t = encodeURIComponent(title);
    const u = encodeURIComponent(url);
    const shares = {
      twitter: () => `https://twitter.com/intent/tweet?text=${t}&url=${u}`,
      linkedin: () => `https://www.linkedin.com/sharing/share-offsite/?url=${u}`,
      facebook: () => `https://www.facebook.com/sharer/sharer.php?u=${u}`,
      reddit: () => `https://www.reddit.com/submit?url=${u}&title=${t}`,
      hn: () => `https://news.ycombinator.com/submitlink?u=${u}&t=${t}`,
      telegram: () => `https://t.me/share/url?url=${u}&text=${t}`,
      whatsapp: () => `https://wa.me/?text=${encodeURIComponent(title + " " + url)}`,
      email: () => `mailto:?subject=${t}&body=${encodeURIComponent("Thought you'd enjoy this: " + url)}`,
    };
    bar.querySelectorAll("a[data-share]").forEach((a) => {
      const k = a.getAttribute("data-share");
      if (shares[k]) a.setAttribute("href", shares[k]());
      if (k !== "email") a.setAttribute("target", "_blank");
    });

    // Native share sheet (mobile + supported desktops)
    const nativeBtn = bar.querySelector('[data-share="native"]');
    if (nativeBtn && navigator.share) {
      nativeBtn.hidden = false;
      nativeBtn.addEventListener("click", () => {
        navigator.share({ title, text: title, url }).catch(() => {});
      });
    }

    const copyBtn = bar.querySelector('[data-share="copy"]');
    copyBtn?.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(url);
        const old = copyBtn.textContent;
        copyBtn.textContent = "✓ Copied";
        setTimeout(() => (copyBtn.textContent = old), 1500);
      } catch (e) {}
    });

    render();
  })();
</script>
