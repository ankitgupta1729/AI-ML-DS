---
import { SUPABASE, AUTH } from "../consts";
const live = !!(SUPABASE.url && SUPABASE.anonKey);
const providers = AUTH.providers || [];
const hasSocial = providers.length > 0;
---

<!-- Header auth control -->
<div id="auth-root" class="relative" data-live={live ? "1" : ""} data-url={SUPABASE.url} data-key={SUPABASE.anonKey}>
  <button id="auth-signin-btn" class="rounded-lg bg-brand-600 px-3 py-1.5 text-sm font-semibold text-white transition hover:bg-brand-700">
    Sign in
  </button>
  <button id="auth-user-btn" class="hidden items-center gap-2 rounded-full border border-gray-200 py-1 pl-1 pr-3 text-sm font-semibold text-gray-700 transition hover:border-brand-400 dark:border-white/15 dark:text-gray-200">
    <img id="auth-user-avatar" src="" alt="" width="28" height="28" class="h-7 w-7 rounded-full bg-gray-100 dark:bg-white/10" />
    <span id="auth-user-name">You</span>
  </button>

  <!-- Dropdown -->
  <div id="auth-menu" class="absolute right-0 z-50 mt-2 hidden w-52 overflow-hidden rounded-xl border border-gray-200 bg-white py-1 shadow-xl dark:border-white/10 dark:bg-ink">
    <div class="border-b border-gray-100 px-3 py-2 dark:border-white/10">
      <p id="auth-menu-name" class="truncate text-sm font-semibold text-gray-900 dark:text-white"></p>
      <p id="auth-menu-email" class="truncate text-xs text-gray-400"></p>
    </div>
    <a id="auth-menu-profile" href="/profile" class="block px-3 py-2 text-sm text-gray-700 hover:bg-gray-100 dark:text-gray-200 dark:hover:bg-white/5">👤 My profile</a>
    <a href="/write" class="block px-3 py-2 text-sm text-gray-700 hover:bg-gray-100 dark:text-gray-200 dark:hover:bg-white/5">✍️ Write an article</a>
    <a href="/my-posts" class="block px-3 py-2 text-sm text-gray-700 hover:bg-gray-100 dark:text-gray-200 dark:hover:bg-white/5">📝 My posts</a>
    <a href="/progress" class="block px-3 py-2 text-sm text-gray-700 hover:bg-gray-100 dark:text-gray-200 dark:hover:bg-white/5">📈 My progress</a>
    <a href="/reading-list" class="block px-3 py-2 text-sm text-gray-700 hover:bg-gray-100 dark:text-gray-200 dark:hover:bg-white/5">📚 Reading list</a>
    <button id="auth-signout" class="block w-full px-3 py-2 text-left text-sm text-red-600 hover:bg-gray-100 dark:hover:bg-white/5">↩ Sign out</button>
  </div>
</div>

<!-- Auth modal -->
<div id="auth-modal" class="fixed inset-0 z-[60] hidden items-center justify-center overflow-y-auto bg-black/50 p-4 backdrop-blur-sm">
  <div class="my-auto max-h-[92vh] w-full max-w-sm overflow-y-auto rounded-2xl border border-gray-200 bg-white shadow-2xl dark:border-white/10 dark:bg-ink">
    <div class="flex items-center justify-between border-b border-gray-200 px-5 py-3 dark:border-white/10">
      <h3 id="auth-title" class="text-lg font-bold text-gray-900 dark:text-white">Welcome back</h3>
      <button id="auth-modal-close" class="rounded-lg p-1 text-gray-400 hover:bg-gray-100 dark:hover:bg-white/5">✕</button>
    </div>

    <div class="p-5">
      <p id="auth-demo-note" class="mb-3 hidden rounded-lg bg-amber-50 px-3 py-2 text-xs text-amber-700 dark:bg-amber-900/20 dark:text-amber-300">
        ✨ Demo mode — accounts &amp; posts are saved only in this browser. Add Supabase keys for real shared accounts &amp; social login.
      </p>

      <!-- Social (only providers enabled in Supabase + listed in AUTH.providers) -->
      {hasSocial && (
        <div class="grid gap-2">
          {providers.includes("google") && (
            <button data-oauth="google" class="auth-social flex items-center justify-center gap-2 rounded-lg border border-gray-300 px-4 py-2.5 text-sm font-semibold text-gray-700 transition hover:bg-gray-50 dark:border-white/15 dark:text-gray-200 dark:hover:bg-white/5">
              <svg width="18" height="18" viewBox="0 0 24 24"><path fill="#4285F4" d="M23.5 12.3c0-.8-.1-1.6-.2-2.3H12v4.5h6.5a5.6 5.6 0 0 1-2.4 3.6v3h3.9c2.3-2.1 3.5-5.2 3.5-8.8z"/><path fill="#34A853" d="M12 24c3.2 0 5.9-1.1 7.9-2.9l-3.9-3c-1 .7-2.4 1.2-4 1.2-3 0-5.6-2-6.5-4.8H1.5v3a12 12 0 0 0 10.5 6.5z"/><path fill="#FBBC05" d="M5.5 14.5a7.2 7.2 0 0 1 0-4.6v-3H1.5a12 12 0 0 0 0 10.6l4-3z"/><path fill="#EA4335" d="M12 4.8c1.8 0 3.3.6 4.5 1.8l3.4-3.4A12 12 0 0 0 1.5 6.9l4 3C6.4 7.1 9 4.8 12 4.8z"/></svg>
              Continue with Google
            </button>
          )}
          <div class="grid gap-2" class:list={[providers.includes("github") && providers.includes("facebook") ? "grid-cols-2" : "grid-cols-1"]}>
            {providers.includes("github") && (
              <button data-oauth="github" class="auth-social flex items-center justify-center gap-2 rounded-lg border border-gray-300 px-3 py-2.5 text-sm font-semibold text-gray-700 transition hover:bg-gray-50 dark:border-white/15 dark:text-gray-200 dark:hover:bg-white/5">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.2.8-.6v-2c-3.2.7-3.9-1.4-3.9-1.4-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17 4.6 18 4.9 18 4.9c.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.7 18.3.5 12 .5z"/></svg>
                GitHub
              </button>
            )}
            {providers.includes("facebook") && (
              <button data-oauth="facebook" class="auth-social flex items-center justify-center gap-2 rounded-lg border border-gray-300 px-3 py-2.5 text-sm font-semibold text-gray-700 transition hover:bg-gray-50 dark:border-white/15 dark:text-gray-200 dark:hover:bg-white/5">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="#1877F2"><path d="M24 12a12 12 0 1 0-13.9 11.9v-8.4H7.1V12h3V9.4c0-3 1.8-4.6 4.5-4.6 1.3 0 2.7.2 2.7.2v2.9h-1.5c-1.5 0-2 .9-2 1.9V12h3.3l-.5 3.5h-2.8v8.4A12 12 0 0 0 24 12z"/></svg>
                Facebook
              </button>
            )}
          </div>
        </div>
      )}

      {hasSocial && AUTH.emailPassword && (
        <div class="my-4 flex items-center gap-3 text-xs text-gray-400"><span class="h-px flex-1 bg-gray-200 dark:bg-white/10"></span>or with email<span class="h-px flex-1 bg-gray-200 dark:bg-white/10"></span></div>
      )}

      <form id="auth-form" class="space-y-3">
        <input id="auth-name" type="text" placeholder="Display name" class="hidden w-full rounded-lg border border-gray-300 bg-transparent px-3 py-2 text-sm outline-none focus:border-brand-500 dark:border-white/15" />
        <input id="auth-email" type="email" required placeholder="Email" class="w-full rounded-lg border border-gray-300 bg-transparent px-3 py-2 text-sm outline-none focus:border-brand-500 dark:border-white/15" />
        <input id="auth-password" type="password" required minlength="6" placeholder="Password" class="w-full rounded-lg border border-gray-300 bg-transparent px-3 py-2 text-sm outline-none focus:border-brand-500 dark:border-white/15" />
        <p id="auth-error" class="hidden text-sm text-red-500"></p>
        <button type="submit" id="auth-submit" class="w-full rounded-lg bg-brand-600 px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-brand-700">Sign in</button>
      </form>

      <p class="mt-3 text-center text-sm text-gray-500 dark:text-gray-400">
        <span id="auth-switch-text">New here?</span>
        <button id="auth-switch" class="font-semibold text-brand-600 hover:underline dark:text-brand-300">Create an account</button>
      </p>
    </div>
  </div>
</div>

<script is:inline define:vars={{ live, url: SUPABASE.url, key: SUPABASE.anonKey }}>
  (function () {
    const root = document.getElementById("auth-root");
    if (!root) return;
    // The header has a backdrop-filter, which makes position:fixed anchor to
    // the header instead of the viewport. Move the modal to <body> so it
    // centers in the real viewport.
    const modalEl = document.getElementById("auth-modal");
    if (modalEl && modalEl.parentElement !== document.body) document.body.appendChild(modalEl);
    const dice = (s) => "https://api.dicebear.com/9.x/thumbs/svg?seed=" + encodeURIComponent(s || "you") + "&radius=50";
    const $ = (id) => document.getElementById(id);
    let supabase = null;
    let mode = "signin";

    const listeners = [];
    const PolyAuth = {
      live,
      user: null,
      onChange(cb) { listeners.push(cb); cb(this.user); },
      _emit() { listeners.forEach((cb) => cb(this.user)); document.dispatchEvent(new CustomEvent("polyauth", { detail: this.user })); },
      openModal() { openModal("signin"); },
      signOut: async () => {
        if (live && supabase) { await supabase.auth.signOut(); }
        localStorage.removeItem("polyUser");
        setUser(null);
      },
    };
    window.PolyAuth = PolyAuth;

    function setUser(u) {
      PolyAuth.user = u;
      if (u) {
        $("auth-signin-btn").classList.add("hidden");
        $("auth-user-btn").classList.remove("hidden");
        $("auth-user-btn").classList.add("flex");
        $("auth-user-avatar").src = u.avatar || dice(u.email || u.name);
        $("auth-user-name").textContent = (u.name || "You").split(" ")[0];
        $("auth-menu-name").textContent = u.name || "You";
        $("auth-menu-email").textContent = u.email || "";
        if (u.id) $("auth-menu-profile").href = "/profile?id=" + u.id;
      } else {
        $("auth-signin-btn").classList.remove("hidden");
        $("auth-user-btn").classList.add("hidden");
        $("auth-user-btn").classList.remove("flex");
        $("auth-menu").classList.add("hidden");
      }
      PolyAuth._emit();
    }

    function normalize(su) {
      if (!su) return null;
      const m = su.user_metadata || {};
      return { id: su.id, email: su.email, name: m.full_name || m.name || m.user_name || (su.email || "").split("@")[0], avatar: m.avatar_url || dice(su.email) };
    }

    // Shared Supabase client for the whole app (reused so the auth session
    // is attached everywhere). Returns null in demo mode.
    window.polyDB = async function () {
      if (!live) return null;
      if (window.PolySB) return window.PolySB;
      const { createClient } = await import("https://esm.sh/@supabase/supabase-js@2");
      window.PolySB = createClient(url, key);
      return window.PolySB;
    };

    async function upsertProfile(u) {
      if (!u) return;
      try {
        const sb = await window.polyDB();
        if (sb) await sb.from("profiles").upsert({ id: u.id, name: u.name, avatar_url: u.avatar }, { onConflict: "id" });
      } catch (e) {}
    }

    async function initSupabase() {
      try {
        supabase = await window.polyDB();
        const { data } = await supabase.auth.getSession();
        const u = normalize(data.session && data.session.user);
        setUser(u);
        upsertProfile(u);
        supabase.auth.onAuthStateChange((_e, session) => {
          const nu = normalize(session && session.user);
          setUser(nu);
          upsertProfile(nu);
        });
      } catch (e) { console.warn("Supabase auth unavailable", e); }
    }

    // ---- Modal ----
    function openModal(m) {
      mode = m;
      $("auth-demo-note").classList.toggle("hidden", live);
      $("auth-error").classList.add("hidden");
      $("auth-name").classList.toggle("hidden", m !== "signup");
      $("auth-title").textContent = m === "signup" ? "Create your account" : "Welcome back";
      $("auth-submit").textContent = m === "signup" ? "Create account" : "Sign in";
      $("auth-switch-text").textContent = m === "signup" ? "Already have an account?" : "New here?";
      $("auth-switch").textContent = m === "signup" ? "Sign in" : "Create an account";
      const modal = $("auth-modal"); modal.classList.remove("hidden"); modal.classList.add("flex");
    }
    function closeModal() { const m = $("auth-modal"); m.classList.add("hidden"); m.classList.remove("flex"); }

    $("auth-signin-btn").addEventListener("click", () => openModal("signin"));
    $("auth-modal-close").addEventListener("click", closeModal);
    $("auth-modal").addEventListener("click", (e) => { if (e.target === $("auth-modal")) closeModal(); });
    $("auth-switch").addEventListener("click", () => openModal(mode === "signup" ? "signin" : "signup"));

    $("auth-user-btn").addEventListener("click", () => $("auth-menu").classList.toggle("hidden"));
    document.addEventListener("click", (e) => { if (!root.contains(e.target)) $("auth-menu").classList.add("hidden"); });
    $("auth-signout").addEventListener("click", () => PolyAuth.signOut());

    function showErr(msg) { const e = $("auth-error"); e.textContent = msg; e.classList.remove("hidden"); }

    $("auth-form").addEventListener("submit", async (e) => {
      e.preventDefault();
      const email = $("auth-email").value.trim();
      const password = $("auth-password").value;
      const name = $("auth-name").value.trim();
      if (live) {
        try {
          if (mode === "signup") {
            const { error } = await supabase.auth.signUp({ email, password, options: { data: { full_name: name || email.split("@")[0] } } });
            if (error) return showErr(error.message);
            showErr("Check your email to confirm your account ✉️");
            return;
          } else {
            const { error } = await supabase.auth.signInWithPassword({ email, password });
            if (error) return showErr(error.message);
          }
        } catch (err) { return showErr("Auth error — try again."); }
        closeModal();
      } else {
        // Demo mode: store locally
        const u = { id: "demo-" + btoa(email).slice(0, 8), email, name: name || email.split("@")[0], avatar: dice(email) };
        localStorage.setItem("polyUser", JSON.stringify(u));
        setUser(u); closeModal();
      }
    });

    document.querySelectorAll(".auth-social").forEach((b) => b.addEventListener("click", async () => {
      const provider = b.getAttribute("data-oauth");
      if (live) {
        try { await supabase.auth.signInWithOAuth({ provider, options: { redirectTo: location.href } }); } catch (e) { showErr("Could not start " + provider + " login."); }
      } else {
        const label = provider.charAt(0).toUpperCase() + provider.slice(1);
        showErr("🔒 Real " + label + " sign-in activates once the site owner connects an auth provider (Supabase). It can't run on a static demo because OAuth needs a server-side secret. For now, use the email demo sign-in below.");
      }
    }));

    // ---- Init ----
    if (live) {
      initSupabase();
    } else {
      try { const u = JSON.parse(localStorage.getItem("polyUser") || "null"); setUser(u); } catch (e) { setUser(null); }
    }
  })();
</script>
