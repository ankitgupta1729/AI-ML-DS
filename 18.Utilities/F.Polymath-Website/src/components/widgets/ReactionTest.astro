---
const uid = "rt" + Math.random().toString(36).slice(2, 8);
---

<div id={uid} class="not-prose rounded-2xl border border-gray-200 bg-white p-5 shadow-sm dark:border-white/10 dark:bg-white/[0.03]">
  <h4 class="m-0 mb-3 flex items-center gap-2 font-bold text-gray-900 dark:text-white"><span class="text-xl">⚡</span> Reaction Speed</h4>
  <button data-pad class="grid h-44 w-full place-items-center rounded-2xl bg-slate-700 text-center text-lg font-bold text-white transition">
    Click to start
  </button>
  <p class="mt-3 text-center text-sm text-gray-500" data-best></p>
</div>

<script is:inline define:vars={{ uid }}>
  (function () {
    const root = document.getElementById(uid);
    if (!root) return;
    const pad = root.querySelector("[data-pad]");
    const bestEl = root.querySelector("[data-best]");
    let state = "idle", t0 = 0, timer = null;
    const KEY = "reactionBest";
    function showBest() { const b = localStorage.getItem(KEY); bestEl.textContent = b ? "🏅 Best: " + b + " ms" : "Average human reaction is ~250 ms."; }
    showBest();

    function set(bg, txt) { pad.style.background = bg; pad.textContent = txt; }
    pad.addEventListener("click", () => {
      if (state === "idle" || state === "done" || state === "early") {
        state = "wait"; set("#b91c1c", "Wait for green…");
        timer = setTimeout(() => { state = "go"; t0 = performance.now(); set("#16a34a", "CLICK!"); }, 1000 + Math.random() * 2500);
      } else if (state === "wait") {
        clearTimeout(timer); state = "early"; set("#475569", "Too soon! Click to retry");
      } else if (state === "go") {
        const ms = Math.round(performance.now() - t0); state = "done";
        const b = +localStorage.getItem(KEY) || Infinity;
        if (ms < b) localStorage.setItem(KEY, ms);
        set("#334155", ms + " ms — click to retry");
        showBest();
      }
    });
  })();
</script>
