---
// Interactive least-squares regression. Click to add points and watch the
// best-fit line, its equation, and R² update live.
const uid = "lr" + Math.random().toString(36).slice(2, 8);
---

<div
  id={uid}
  class="not-prose my-8 rounded-2xl border border-gray-200 bg-white p-5 shadow-sm dark:border-white/10 dark:bg-white/[0.03]"
>
  <div class="mb-3 flex items-center gap-2">
    <span class="text-xl">📉</span>
    <h4 class="m-0 font-bold text-gray-900 dark:text-white">Linear regression — find the best-fit line</h4>
  </div>
  <p class="mt-0 mb-3 text-sm text-gray-600 dark:text-gray-400">
    <b>Click anywhere</b> on the chart to drop data points. The line that minimises the total squared vertical distance updates instantly.
  </p>

  <svg viewBox="0 0 420 260" class="w-full cursor-crosshair rounded-xl bg-gray-50 dark:bg-white/5" data-canvas aria-hidden="true"></svg>

  <div class="mt-3 flex flex-wrap items-center gap-2">
    <button data-rand class="rounded-lg border border-gray-300 px-3 py-1.5 text-sm font-semibold text-gray-700 hover:border-brand-400 dark:border-white/15 dark:text-gray-200">Add random cloud</button>
    <button data-clear class="rounded-lg border border-gray-300 px-3 py-1.5 text-sm font-semibold text-gray-700 hover:border-brand-400 dark:border-white/15 dark:text-gray-200">Clear</button>
    <label class="ml-2 inline-flex items-center gap-1 text-sm text-gray-600 dark:text-gray-300"><input data-res type="checkbox" class="accent-brand-600" /> show residuals</label>
    <span class="ml-auto font-mono text-sm text-gray-700 dark:text-gray-200" data-eq>add points…</span>
  </div>
</div>

<script is:inline define:vars={{ uid }}>
  (function () {
    const root = document.getElementById(uid);
    if (!root) return;
    const svg = root.querySelector("[data-canvas]");
    const eq = root.querySelector("[data-eq]");
    const resChk = root.querySelector("[data-res]");
    const W = 420, H = 260, PAD = 20;
    let pts = [];

    function fit() {
      const n = pts.length;
      if (n < 2) return null;
      let sx = 0, sy = 0, sxy = 0, sxx = 0, syy = 0;
      pts.forEach((p) => { sx += p.x; sy += p.y; sxy += p.x * p.y; sxx += p.x * p.x; syy += p.y * p.y; });
      const denom = n * sxx - sx * sx;
      if (Math.abs(denom) < 1e-9) return null;
      const m = (n * sxy - sx * sy) / denom;
      const b = (sy - m * sx) / n;
      // R²
      const meanY = sy / n;
      let ssTot = 0, ssRes = 0;
      pts.forEach((p) => { const pred = m * p.x + b; ssRes += (p.y - pred) ** 2; ssTot += (p.y - meanY) ** 2; });
      const r2 = ssTot > 0 ? 1 - ssRes / ssTot : 1;
      return { m, b, r2 };
    }

    // data coords: x 0..10, y 0..10 mapped to svg
    const sx = (x) => PAD + (x / 10) * (W - 2 * PAD);
    const sy = (y) => H - PAD - (y / 10) * (H - 2 * PAD);

    function draw() {
      let s = '<line x1="' + PAD + '" y1="' + (H - PAD) + '" x2="' + (W - PAD) + '" y2="' + (H - PAD) + '" stroke="currentColor" stroke-opacity="0.2"/>';
      s += '<line x1="' + PAD + '" y1="' + PAD + '" x2="' + PAD + '" y2="' + (H - PAD) + '" stroke="currentColor" stroke-opacity="0.2"/>';
      const f = fit();
      if (f && resChk.checked) {
        pts.forEach((p) => { const py = f.m * p.x + f.b; s += '<line x1="' + sx(p.x) + '" y1="' + sy(p.y) + '" x2="' + sx(p.x) + '" y2="' + sy(py) + '" stroke="#f59e0b" stroke-width="1.5" opacity="0.7"/>'; });
      }
      if (f) {
        const y0 = f.b, y10 = f.m * 10 + f.b;
        s += '<line x1="' + sx(0) + '" y1="' + sy(y0) + '" x2="' + sx(10) + '" y2="' + sy(y10) + '" stroke="#4f46e5" stroke-width="2.5"/>';
      }
      pts.forEach((p) => { s += '<circle cx="' + sx(p.x) + '" cy="' + sy(p.y) + '" r="4.5" fill="#ec4899" stroke="white" stroke-width="1"/>'; });
      svg.innerHTML = s;
      if (f) eq.textContent = "y = " + f.m.toFixed(2) + "x + " + f.b.toFixed(2) + "   ·   R² = " + f.r2.toFixed(3);
      else eq.textContent = pts.length ? "add one more point…" : "add points…";
    }

    svg.addEventListener("click", (e) => {
      const rect = svg.getBoundingClientRect();
      const px = ((e.clientX - rect.left) / rect.width) * W;
      const py = ((e.clientY - rect.top) / rect.height) * H;
      const x = ((px - PAD) / (W - 2 * PAD)) * 10;
      const y = ((H - PAD - py) / (H - 2 * PAD)) * 10;
      if (x >= 0 && x <= 10 && y >= 0 && y <= 10) { pts.push({ x, y }); draw(); }
    });
    root.querySelector("[data-rand]").addEventListener("click", () => {
      const m = 0.4 + Math.random() * 0.8, b = 1 + Math.random() * 3;
      for (let i = 0; i < 12; i++) { const x = Math.random() * 10; let y = m * x + b + (Math.random() - 0.5) * 3; y = Math.max(0, Math.min(10, y)); pts.push({ x, y }); }
      draw();
    });
    root.querySelector("[data-clear]").addEventListener("click", () => { pts = []; draw(); });
    resChk.addEventListener("change", draw);
    draw();
  })();
</script>
