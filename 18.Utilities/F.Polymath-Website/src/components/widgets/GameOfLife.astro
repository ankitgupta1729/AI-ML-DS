---
// Conway's Game of Life — a tiny set of rules producing astonishing emergent
// behaviour. Click cells, drop a glider, and watch life unfold.
const uid = "gol" + Math.random().toString(36).slice(2, 8);
---

<div id={uid} class="not-prose my-8 rounded-2xl border border-gray-200 bg-white p-5 shadow-sm dark:border-white/10 dark:bg-white/[0.03]">
  <div class="mb-3 flex items-center gap-2">
    <span class="text-xl">🦠</span>
    <h4 class="m-0 font-bold text-gray-900 dark:text-white">Conway's Game of Life</h4>
  </div>
  <p class="mt-0 mb-3 text-sm text-gray-600 dark:text-gray-400">
    Three rules, infinite complexity. A cell lives if it has 2–3 neighbours, is born with exactly 3, else dies. <b>Click cells</b> to draw, then press play.
  </p>
  <canvas data-canvas width="480" height="320" class="mx-auto block w-full cursor-crosshair rounded-xl bg-gray-900"></canvas>
  <div class="mt-3 flex flex-wrap items-center gap-2">
    <button data-play class="rounded-lg bg-brand-600 px-4 py-2 text-sm font-semibold text-white hover:bg-brand-700">▶ Play</button>
    <button data-step class="rounded-lg border border-gray-300 px-3 py-2 text-sm font-semibold text-gray-700 hover:border-brand-400 dark:border-white/15 dark:text-gray-200">Step</button>
    <button data-rand class="rounded-lg border border-gray-300 px-3 py-2 text-sm font-semibold text-gray-700 hover:border-brand-400 dark:border-white/15 dark:text-gray-200">Random</button>
    <button data-glider class="rounded-lg border border-gray-300 px-3 py-2 text-sm font-semibold text-gray-700 hover:border-brand-400 dark:border-white/15 dark:text-gray-200">Glider gun</button>
    <button data-clear class="rounded-lg border border-gray-300 px-3 py-2 text-sm font-semibold text-gray-700 hover:border-brand-400 dark:border-white/15 dark:text-gray-200">Clear</button>
    <span class="ml-auto text-sm text-gray-500" data-gen>gen 0</span>
  </div>
</div>

<script is:inline define:vars={{ uid }}>
  (function () {
    const root = document.getElementById(uid);
    if (!root) return;
    const cv = root.querySelector("[data-canvas]");
    const ctx = cv.getContext("2d");
    const COLS = 60, ROWS = 40, CELL = cv.width / COLS;
    let grid = make(), gen = 0, timer = null;

    function make() { return Array.from({ length: ROWS }, () => new Array(COLS).fill(0)); }
    function draw() {
      ctx.fillStyle = "#0b0f1a"; ctx.fillRect(0, 0, cv.width, cv.height);
      for (let r = 0; r < ROWS; r++) for (let c = 0; c < COLS; c++) if (grid[r][c]) {
        ctx.fillStyle = "#818cf8"; ctx.fillRect(c * CELL, r * CELL, CELL - 1, CELL - 1);
      }
      root.querySelector("[data-gen]").textContent = "gen " + gen;
    }
    function step() {
      const next = make();
      for (let r = 0; r < ROWS; r++) for (let c = 0; c < COLS; c++) {
        let n = 0;
        for (let dr = -1; dr <= 1; dr++) for (let dc = -1; dc <= 1; dc++) {
          if (!dr && !dc) continue;
          const rr = (r + dr + ROWS) % ROWS, cc = (c + dc + COLS) % COLS;
          n += grid[rr][cc];
        }
        next[r][c] = grid[r][c] ? (n === 2 || n === 3 ? 1 : 0) : (n === 3 ? 1 : 0);
      }
      grid = next; gen++; draw();
    }
    function play() {
      const b = root.querySelector("[data-play]");
      if (timer) { clearInterval(timer); timer = null; b.textContent = "▶ Play"; }
      else { timer = setInterval(step, 90); b.textContent = "⏸ Pause"; }
    }
    cv.addEventListener("click", (e) => {
      const rect = cv.getBoundingClientRect();
      const c = Math.floor((e.clientX - rect.left) / rect.width * COLS);
      const r = Math.floor((e.clientY - rect.top) / rect.height * ROWS);
      if (r >= 0 && r < ROWS && c >= 0 && c < COLS) { grid[r][c] ^= 1; draw(); }
    });
    root.querySelector("[data-play]").addEventListener("click", play);
    root.querySelector("[data-step]").addEventListener("click", step);
    root.querySelector("[data-rand]").addEventListener("click", () => { for (let r = 0; r < ROWS; r++) for (let c = 0; c < COLS; c++) grid[r][c] = Math.random() < 0.28 ? 1 : 0; gen = 0; draw(); });
    root.querySelector("[data-clear]").addEventListener("click", () => { grid = make(); gen = 0; draw(); if (timer) play(); });
    root.querySelector("[data-glider]").addEventListener("click", () => {
      grid = make(); gen = 0;
      // Gosper glider gun
      const gun = [[5,1],[5,2],[6,1],[6,2],[5,11],[6,11],[7,11],[4,12],[8,12],[3,13],[9,13],[3,14],[9,14],[6,15],[4,16],[8,16],[5,17],[6,17],[7,17],[6,18],[3,21],[4,21],[5,21],[3,22],[4,22],[5,22],[2,23],[6,23],[1,25],[2,25],[6,25],[7,25],[3,35],[4,35],[3,36],[4,36]];
      gun.forEach(([r, c]) => { if (r < ROWS && c < COLS) grid[r + 2][c + 2] = 1; });
      draw();
    });
    // start with a glider
    [[1,2],[2,3],[3,1],[3,2],[3,3]].forEach(([r, c]) => grid[r + 5][c + 5] = 1);
    draw();
  })();
</script>
