---
// Geometric Brownian motion — the classic model of a "random walk" stock price.
// Same drift & volatility, wildly different outcomes: why markets are so hard to predict.
const uid = "ss" + Math.random().toString(36).slice(2, 8);
---

<div id={uid} class="not-prose my-8 rounded-2xl border border-gray-200 bg-white p-5 shadow-sm dark:border-white/10 dark:bg-white/[0.03]">
  <div class="mb-3 flex items-center gap-2">
    <span class="text-xl">📉</span>
    <h4 class="m-0 font-bold text-gray-900 dark:text-white">Why markets are unpredictable — a random walk</h4>
  </div>
  <p class="mt-0 mb-3 text-sm text-gray-600 dark:text-gray-400">
    Each line is a possible 1-year price path with the <b>same</b> average return and volatility — yet they scatter everywhere. That randomness is exactly why "beating the market" is so hard.
  </p>
  <svg viewBox="0 0 600 240" class="w-full" data-chart aria-hidden="true"></svg>
  <div class="mt-2 grid gap-4 sm:grid-cols-2">
    <label class="block text-sm"><span class="flex justify-between font-medium text-gray-700 dark:text-gray-300">Annual return (drift) <b data-out="mu" class="text-brand-600 dark:text-brand-300"></b></span>
      <input data-in="mu" type="range" min="-10" max="20" step="1" value="8" class="mt-1 w-full accent-brand-600" /></label>
    <label class="block text-sm"><span class="flex justify-between font-medium text-gray-700 dark:text-gray-300">Volatility <b data-out="sig" class="text-brand-600 dark:text-brand-300"></b></span>
      <input data-in="sig" type="range" min="5" max="60" step="1" value="20" class="mt-1 w-full accent-brand-600" /></label>
  </div>
  <button data-run class="mt-3 rounded-lg bg-brand-600 px-4 py-2 text-sm font-semibold text-white hover:bg-brand-700">🎲 Run new simulation</button>
  <p class="mt-2 text-xs text-gray-400">Education only, not financial advice.</p>
</div>

<script is:inline define:vars={{ uid }}>
  (function () {
    const root = document.getElementById(uid);
    if (!root) return;
    const svg = root.querySelector("[data-chart]");
    const muIn = root.querySelector('[data-in="mu"]'), sigIn = root.querySelector('[data-in="sig"]');
    const colors = ["#6366f1", "#ec4899", "#14b8a6", "#f59e0b", "#0ea5e9", "#ef4444"];

    function gauss() { let u = 0, v = 0; while (!u) u = Math.random(); while (!v) v = Math.random(); return Math.sqrt(-2 * Math.log(u)) * Math.cos(2 * Math.PI * v); }

    function run() {
      const mu = +muIn.value / 100, sig = +sigIn.value / 100;
      root.querySelector('[data-out="mu"]').textContent = muIn.value + "%";
      root.querySelector('[data-out="sig"]').textContent = sigIn.value + "%";
      const steps = 252, dt = 1 / steps, paths = 6;
      const all = [];
      let maxV = 100, minV = 100;
      for (let p = 0; p < paths; p++) {
        let price = 100; const arr = [100];
        for (let t = 0; t < steps; t++) {
          price *= Math.exp((mu - 0.5 * sig * sig) * dt + sig * Math.sqrt(dt) * gauss());
          arr.push(price); maxV = Math.max(maxV, price); minV = Math.min(minV, price);
        }
        all.push(arr);
      }
      const W = 560, H = 200, X0 = 30, Y0 = 220;
      const sx = (i) => X0 + (i / steps) * W;
      const sy = (v) => Y0 - ((v - minV) / (maxV - minV || 1)) * H;
      let s = '<line x1="' + X0 + '" y1="' + sy(100) + '" x2="' + (X0 + W) + '" y2="' + sy(100) + '" stroke="currentColor" stroke-opacity="0.2" stroke-dasharray="4 4"/><text x="' + (X0 + 2) + '" y="' + (sy(100) - 3) + '" font-size="10" fill="currentColor" opacity="0.5">start</text>';
      all.forEach((arr, p) => {
        const d = arr.map((v, i) => (i ? "L" : "M") + sx(i).toFixed(1) + " " + sy(v).toFixed(1)).join(" ");
        s += '<path d="' + d + '" fill="none" stroke="' + colors[p % colors.length] + '" stroke-width="1.5" opacity="0.85"/>';
      });
      svg.innerHTML = s;
    }
    muIn.addEventListener("input", run); sigIn.addEventListener("input", run);
    root.querySelector("[data-run]").addEventListener("click", run);
    run();
  })();
</script>
