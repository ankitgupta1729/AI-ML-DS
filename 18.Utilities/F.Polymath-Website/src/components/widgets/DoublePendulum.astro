---
// Double pendulum — a textbook example of deterministic chaos. A tiny change
// in starting angle leads to a wildly different path (the butterfly effect).
const uid = "dp" + Math.random().toString(36).slice(2, 8);
---

<div id={uid} class="not-prose rounded-2xl border border-gray-200 bg-white p-5 shadow-sm dark:border-white/10 dark:bg-white/[0.03]">
  <div class="mb-3 flex items-center justify-between">
    <h4 class="m-0 flex items-center gap-2 font-bold text-gray-900 dark:text-white"><span class="text-xl">🌀</span> Double pendulum (chaos)</h4>
  </div>
  <p class="mt-0 mb-3 text-sm text-gray-600 dark:text-gray-400">
    Two linked pendulums obeying simple physics — yet utterly unpredictable. Hit <b>Nudge</b> to see how a 0.1° change explodes into a totally different trajectory.
  </p>
  <canvas data-canvas width="440" height="380" class="mx-auto block w-full max-w-md rounded-xl bg-gray-900"></canvas>
  <div class="mt-3 flex flex-wrap gap-2">
    <button data-toggle class="rounded-lg bg-brand-600 px-4 py-2 text-sm font-semibold text-white hover:bg-brand-700">⏸ Pause</button>
    <button data-nudge class="rounded-lg border border-gray-300 px-3 py-2 text-sm font-semibold text-gray-700 hover:border-brand-400 dark:border-white/15 dark:text-gray-200">Nudge 🦋</button>
    <button data-reset class="rounded-lg border border-gray-300 px-3 py-2 text-sm font-semibold text-gray-700 hover:border-brand-400 dark:border-white/15 dark:text-gray-200">Reset</button>
  </div>
</div>

<script is:inline define:vars={{ uid }}>
  (function () {
    const root = document.getElementById(uid);
    if (!root) return;
    const cv = root.querySelector("[data-canvas]");
    const ctx = cv.getContext("2d");
    const cx = cv.width / 2, cy = 130, L1 = 90, L2 = 90, m1 = 10, m2 = 10, g = 1;
    let p, raf = null, running = true, trail = [];

    function init(offset) {
      p = { a1: Math.PI / 2 + (offset || 0), a2: Math.PI / 2, v1: 0, v2: 0 };
      trail = [];
    }
    function stepPhysics() {
      const { a1, a2, v1, v2 } = p;
      const d = a1 - a2;
      const den = 2 * m1 + m2 - m2 * Math.cos(2 * d);
      const a1a = (-g * (2 * m1 + m2) * Math.sin(a1) - m2 * g * Math.sin(a1 - 2 * a2) - 2 * Math.sin(d) * m2 * (v2 * v2 * L2 + v1 * v1 * L1 * Math.cos(d))) / (L1 * den);
      const a2a = (2 * Math.sin(d) * (v1 * v1 * L1 * (m1 + m2) + g * (m1 + m2) * Math.cos(a1) + v2 * v2 * L2 * m2 * Math.cos(d))) / (L2 * den);
      p.v1 += a1a; p.v2 += a2a; p.a1 += p.v1; p.a2 += p.v2;
    }
    function draw() {
      const x1 = cx + L1 * Math.sin(p.a1), y1 = cy + L1 * Math.cos(p.a1);
      const x2 = x1 + L2 * Math.sin(p.a2), y2 = y1 + L2 * Math.cos(p.a2);
      trail.push([x2, y2]); if (trail.length > 250) trail.shift();
      ctx.fillStyle = "#0b0f1a"; ctx.fillRect(0, 0, cv.width, cv.height);
      // trail
      for (let i = 1; i < trail.length; i++) {
        ctx.strokeStyle = "rgba(236,72,153," + (i / trail.length) * 0.8 + ")";
        ctx.lineWidth = 2; ctx.beginPath(); ctx.moveTo(trail[i - 1][0], trail[i - 1][1]); ctx.lineTo(trail[i][0], trail[i][1]); ctx.stroke();
      }
      // arms
      ctx.strokeStyle = "#94a3b8"; ctx.lineWidth = 3; ctx.beginPath(); ctx.moveTo(cx, cy); ctx.lineTo(x1, y1); ctx.lineTo(x2, y2); ctx.stroke();
      ctx.fillStyle = "#818cf8"; [[x1, y1], [x2, y2]].forEach(([x, y]) => { ctx.beginPath(); ctx.arc(x, y, 8, 0, 7); ctx.fill(); });
    }
    function loop() { if (!running) return; for (let i = 0; i < 3; i++) stepPhysics(); draw(); raf = requestAnimationFrame(loop); }
    function start() { if (!raf) loop(); }

    root.querySelector("[data-toggle]").addEventListener("click", () => {
      running = !running; root.querySelector("[data-toggle]").textContent = running ? "⏸ Pause" : "▶ Play";
      if (running) { raf = null; start(); }
    });
    root.querySelector("[data-nudge]").addEventListener("click", () => { p.a1 += 0.0017; });
    root.querySelector("[data-reset]").addEventListener("click", () => { init(0); draw(); });

    init(0); running = true; start();
  })();
</script>
