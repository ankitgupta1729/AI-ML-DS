---
// Interactive Monty Hall simulator. Play by hand and watch the stats, or
// auto-run thousands of trials to see "always switch" win ~2/3 of the time.
// Self-contained: no dependencies, scoped by a unique id so multiple
// instances can coexist.
const uid = "mh" + Math.random().toString(36).slice(2, 8);
---

<div
  id={uid}
  class="not-prose my-8 rounded-2xl border border-gray-200 bg-white p-5 shadow-sm dark:border-white/10 dark:bg-white/[0.03]"
>
  <div class="mb-3 flex items-center gap-2">
    <span class="text-xl">🚪</span>
    <h4 class="m-0 font-bold text-gray-900 dark:text-white">Monty Hall — try it yourself</h4>
  </div>
  <p class="mt-0 mb-4 text-sm text-gray-600 dark:text-gray-400" data-msg>
    Pick a door. The host will reveal a goat, then you decide: stick or switch.
  </p>

  <div class="grid grid-cols-3 gap-3" data-doors>
    {
      [0, 1, 2].map((i) => (
        <button
          data-door={i}
          class="group relative aspect-[3/4] overflow-hidden rounded-xl border-2 border-gray-300 bg-gradient-to-b from-amber-100 to-amber-200 text-5xl transition hover:border-brand-500 dark:border-white/15 dark:from-amber-900/30 dark:to-amber-800/20"
        >
          <span data-face>🚪</span>
          <span class="absolute bottom-1 left-0 right-0 text-xs font-semibold text-amber-900/70 dark:text-amber-200/70">
            Door {i + 1}
          </span>
        </button>
      ))
    }
  </div>

  <div class="mt-4 flex flex-wrap items-center gap-2" data-actions></div>

  <div class="mt-5 grid grid-cols-2 gap-3 text-center text-sm">
    <div class="rounded-xl bg-green-50 p-3 dark:bg-green-900/20">
      <div class="text-xs font-semibold uppercase tracking-wide text-green-700 dark:text-green-300">Switching</div>
      <div class="text-lg font-extrabold text-green-700 dark:text-green-300" data-stat-switch>0 / 0</div>
      <div class="text-xs text-green-700/70 dark:text-green-300/70" data-stat-switch-pct>—</div>
    </div>
    <div class="rounded-xl bg-rose-50 p-3 dark:bg-rose-900/20">
      <div class="text-xs font-semibold uppercase tracking-wide text-rose-700 dark:text-rose-300">Staying</div>
      <div class="text-lg font-extrabold text-rose-700 dark:text-rose-300" data-stat-stay>0 / 0</div>
      <div class="text-xs text-rose-700/70 dark:text-rose-300/70" data-stat-stay-pct>—</div>
    </div>
  </div>

  <div class="mt-3 flex flex-wrap gap-2">
    <button data-sim="100" class="rounded-lg bg-brand-600 px-3 py-1.5 text-sm font-semibold text-white transition hover:bg-brand-700">Auto-run 1,000× (always switch)</button>
    <button data-reset class="rounded-lg border border-gray-300 px-3 py-1.5 text-sm font-semibold text-gray-700 transition hover:border-brand-400 dark:border-white/15 dark:text-gray-200">Reset</button>
  </div>
</div>

<script is:inline define:vars={{ uid }}>
  (function () {
    const root = document.getElementById(uid);
    if (!root) return;
    const doorsEl = root.querySelector("[data-doors]");
    const doorBtns = [...root.querySelectorAll("[data-door]")];
    const msg = root.querySelector("[data-msg]");
    const actions = root.querySelector("[data-actions]");
    const stats = { switchWins: 0, switchTot: 0, stayWins: 0, stayTot: 0 };

    let car, pick, revealed, phase;

    function rint(n) { return Math.floor(Math.random() * n); }

    function renderStats() {
      root.querySelector("[data-stat-switch]").textContent = stats.switchWins + " / " + stats.switchTot;
      root.querySelector("[data-stat-stay]").textContent = stats.stayWins + " / " + stats.stayTot;
      root.querySelector("[data-stat-switch-pct]").textContent =
        stats.switchTot ? Math.round((stats.switchWins / stats.switchTot) * 100) + "% win rate" : "—";
      root.querySelector("[data-stat-stay-pct]").textContent =
        stats.stayTot ? Math.round((stats.stayWins / stats.stayTot) * 100) + "% win rate" : "—";
    }

    function setFace(i, txt) { doorBtns[i].querySelector("[data-face]").textContent = txt; }
    function resetDoors() { doorBtns.forEach((b, i) => { setFace(i, "🚪"); b.classList.remove("ring-4", "ring-brand-400", "opacity-60"); b.disabled = false; }); }

    function newRound() {
      car = rint(3); pick = null; revealed = null; phase = "pick";
      resetDoors();
      actions.innerHTML = "";
      msg.textContent = "Pick a door. The host will reveal a goat, then you decide: stick or switch.";
    }

    function btn(label, cls, on) {
      const b = document.createElement("button");
      b.textContent = label;
      b.className = cls;
      b.addEventListener("click", on);
      return b;
    }

    function onPick(i) {
      if (phase !== "pick") return;
      pick = i;
      doorBtns[i].classList.add("ring-4", "ring-brand-400");
      // Host reveals a goat that is neither the pick nor the car.
      const options = [0, 1, 2].filter((d) => d !== pick && d !== car);
      revealed = options[rint(options.length)];
      setFace(revealed, "🐐");
      doorBtns[revealed].classList.add("opacity-60");
      doorBtns[revealed].disabled = true;
      phase = "decide";
      const other = [0, 1, 2].find((d) => d !== pick && d !== revealed);
      msg.textContent = "Door " + (revealed + 1) + " was a goat 🐐. Stick with Door " + (pick + 1) + ", or switch to Door " + (other + 1) + "?";
      actions.innerHTML = "";
      actions.appendChild(btn("Stay with Door " + (pick + 1), "rounded-lg border border-rose-300 px-3 py-1.5 text-sm font-semibold text-rose-700 hover:bg-rose-50 dark:border-rose-500/40 dark:text-rose-300", () => decide(false)));
      actions.appendChild(btn("Switch to Door " + (other + 1), "rounded-lg bg-green-600 px-3 py-1.5 text-sm font-semibold text-white hover:bg-green-700", () => decide(true)));
    }

    function decide(doSwitch) {
      if (phase !== "decide") return;
      const other = [0, 1, 2].find((d) => d !== pick && d !== revealed);
      const finalPick = doSwitch ? other : pick;
      const won = finalPick === car;
      [0, 1, 2].forEach((d) => setFace(d, d === car ? "🚗" : "🐐"));
      if (doSwitch) { stats.switchTot++; if (won) stats.switchWins++; }
      else { stats.stayTot++; if (won) stats.stayWins++; }
      renderStats();
      phase = "done";
      msg.textContent = (won ? "🎉 You won the car!" : "😅 A goat. Better luck next time!") +
        " (You " + (doSwitch ? "switched" : "stayed") + ".)";
      actions.innerHTML = "";
      actions.appendChild(btn("Play again →", "rounded-lg bg-brand-600 px-3 py-1.5 text-sm font-semibold text-white hover:bg-brand-700", newRound));
    }

    doorBtns.forEach((b, i) => b.addEventListener("click", () => onPick(i)));

    root.querySelector("[data-sim]").addEventListener("click", () => {
      for (let n = 0; n < 1000; n++) {
        const c = rint(3), p = rint(3);
        const rev = [0, 1, 2].filter((d) => d !== p && d !== c);
        const r = rev[rint(rev.length)];
        const sw = [0, 1, 2].find((d) => d !== p && d !== r);
        stats.switchTot++; if (sw === c) stats.switchWins++;
      }
      renderStats();
      msg.textContent = "Ran 1,000 games always switching. Notice it wins about 2 out of 3 times!";
    });

    root.querySelector("[data-reset]").addEventListener("click", () => {
      stats.switchWins = stats.switchTot = stats.stayWins = stats.stayTot = 0;
      renderStats(); newRound();
    });

    newRound();
    renderStats();
  })();
</script>
