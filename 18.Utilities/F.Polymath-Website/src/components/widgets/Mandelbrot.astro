---
// Mandelbrot set explorer — infinite fractal detail from one tiny formula
// z → z² + c. Click to zoom in and discover endless self-similar worlds.
const uid = "mb" + Math.random().toString(36).slice(2, 8);
---

<div id={uid} class="not-prose rounded-2xl border border-gray-200 bg-white p-5 shadow-sm dark:border-white/10 dark:bg-white/[0.03]">
  <div class="mb-3 flex items-center justify-between">
    <h4 class="m-0 flex items-center gap-2 font-bold text-gray-900 dark:text-white"><span class="text-xl">🪐</span> Mandelbrot explorer</h4>
  </div>
  <p class="mt-0 mb-3 text-sm text-gray-600 dark:text-gray-400">
    Infinite complexity from <b>z → z² + c</b>. <b>Click to zoom in</b> (Shift-click to zoom out) and fall into the fractal.
  </p>
  <canvas data-canvas width="420" height="320" class="mx-auto block w-full max-w-lg cursor-zoom-in rounded-xl bg-black"></canvas>
  <div class="mt-3 flex flex-wrap items-center gap-2">
    <button data-reset class="rounded-lg border border-gray-300 px-3 py-2 text-sm font-semibold text-gray-700 hover:border-brand-400 dark:border-white/15 dark:text-gray-200">Reset view</button>
    <span class="ml-auto text-xs text-gray-400" data-zoom></span>
  </div>
</div>

<script is:inline define:vars={{ uid }}>
  (function () {
    const root = document.getElementById(uid);
    if (!root) return;
    const cv = root.querySelector("[data-canvas]");
    const ctx = cv.getContext("2d");
    const W = cv.width, H = cv.height;
    let cxC = -0.6, cyC = 0, scale = 3.2; // span across width
    const home = { cxC: -0.6, cyC: 0, scale: 3.2 };

    function render() {
      const img = ctx.createImageData(W, H);
      const d = img.data;
      const maxIter = Math.min(600, 120 + Math.round(40 * Math.log2(home.scale / scale + 1)));
      const aspect = H / W;
      for (let py = 0; py < H; py++) {
        const y0 = cyC + (py / H - 0.5) * scale * aspect;
        for (let px = 0; px < W; px++) {
          const x0 = cxC + (px / W - 0.5) * scale;
          let x = 0, y = 0, i = 0;
          while (x * x + y * y <= 4 && i < maxIter) { const xt = x * x - y * y + x0; y = 2 * x * y + y0; x = xt; i++; }
          const o = (py * W + px) * 4;
          if (i === maxIter) { d[o] = d[o + 1] = d[o + 2] = 10; }
          else { const t = i / maxIter; d[o] = Math.round(9 * (1 - t) * t * t * t * 255); d[o + 1] = Math.round(15 * (1 - t) * (1 - t) * t * t * 255); d[o + 2] = Math.round(8.5 * (1 - t) * (1 - t) * (1 - t) * t * 255); }
          d[o + 3] = 255;
        }
      }
      ctx.putImageData(img, 0, 0);
      root.querySelector("[data-zoom]").textContent = "zoom ×" + (home.scale / scale).toFixed(1);
    }
    cv.addEventListener("click", (e) => {
      const rect = cv.getBoundingClientRect();
      const aspect = H / W;
      cxC += ((e.clientX - rect.left) / rect.width - 0.5) * scale;
      cyC += ((e.clientY - rect.top) / rect.height - 0.5) * scale * aspect;
      scale *= e.shiftKey ? 2 : 0.5;
      render();
    });
    root.querySelector("[data-reset]").addEventListener("click", () => { cxC = home.cxC; cyC = home.cyC; scale = home.scale; render(); });
    render();
  })();
</script>
