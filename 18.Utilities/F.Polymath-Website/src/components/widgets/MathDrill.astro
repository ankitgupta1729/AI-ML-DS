---
const uid = "md" + Math.random().toString(36).slice(2, 8);
---

<div id={uid} class="not-prose rounded-2xl border border-gray-200 bg-white p-5 shadow-sm dark:border-white/10 dark:bg-white/[0.03]">
  <div class="mb-3 flex items-center justify-between">
    <h4 class="m-0 flex items-center gap-2 font-bold text-gray-900 dark:text-white"><span class="text-xl">➗</span> Math Speed Drill</h4>
    <div class="text-sm font-semibold text-gray-500"><span data-time>30</span>s · score <span data-score class="text-brand-600 dark:text-brand-300">0</span></div>
  </div>
  <div data-idle class="text-center">
    <p class="text-sm text-gray-600 dark:text-gray-400">Solve as many as you can in 30 seconds!</p>
    <button data-start class="mt-3 rounded-xl bg-brand-600 px-5 py-2.5 font-semibold text-white hover:bg-brand-700">Start</button>
    <p class="mt-2 text-sm text-gray-500" data-best></p>
  </div>
  <div data-game class="hidden text-center">
    <p data-q class="font-mono text-3xl font-bold text-gray-900 dark:text-white"></p>
    <input data-ans type="number" inputmode="numeric" class="mt-3 w-32 rounded-lg border border-gray-300 bg-transparent px-3 py-2 text-center text-lg outline-none focus:border-brand-500 dark:border-white/15" />
    <p data-feedback class="mt-2 h-5 text-sm font-semibold"></p>
  </div>
</div>

<script is:inline define:vars={{ uid }}>
  (function () {
    const root = document.getElementById(uid);
    if (!root) return;
    const KEY = "mathDrillBest";
    const idle = root.querySelector("[data-idle]"), game = root.querySelector("[data-game]");
    const qEl = root.querySelector("[data-q]"), ansEl = root.querySelector("[data-ans]"), fb = root.querySelector("[data-feedback]");
    let score = 0, left = 30, ans = 0, timer = null;
    function showBest() { const b = localStorage.getItem(KEY); root.querySelector("[data-best]").textContent = b ? "🏅 Best: " + b : ""; }
    showBest();

    function newQ() {
      const ops = ["+", "−", "×"]; const op = ops[(Math.random() * 3) | 0];
      let a, b;
      if (op === "×") { a = (Math.random() * 11 + 2) | 0; b = (Math.random() * 11 + 2) | 0; ans = a * b; }
      else if (op === "+") { a = (Math.random() * 50 + 5) | 0; b = (Math.random() * 50 + 5) | 0; ans = a + b; }
      else { a = (Math.random() * 50 + 20) | 0; b = (Math.random() * a) | 0; ans = a - b; }
      qEl.textContent = a + " " + op + " " + b + " =";
      ansEl.value = ""; ansEl.focus();
    }
    function start() {
      score = 0; left = 30;
      root.querySelector("[data-score]").textContent = 0; root.querySelector("[data-time]").textContent = 30;
      idle.classList.add("hidden"); game.classList.remove("hidden");
      newQ();
      timer = setInterval(() => {
        left--; root.querySelector("[data-time]").textContent = left;
        if (left <= 0) end();
      }, 1000);
    }
    function end() {
      clearInterval(timer); game.classList.add("hidden"); idle.classList.remove("hidden");
      const b = +localStorage.getItem(KEY) || 0; if (score > b) localStorage.setItem(KEY, score);
      showBest();
      root.querySelector("[data-start]").textContent = "Play again (scored " + score + ")";
    }
    ansEl.addEventListener("input", () => {
      if (ansEl.value === "" || ansEl.value === "-") return;
      if (+ansEl.value === ans) {
        score++; root.querySelector("[data-score]").textContent = score;
        fb.textContent = "✓"; fb.style.color = "#16a34a"; newQ();
      }
    });
    root.querySelector("[data-start]").addEventListener("click", start);
  })();
</script>
