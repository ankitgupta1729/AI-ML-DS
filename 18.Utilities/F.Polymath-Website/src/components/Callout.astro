---
interface Props {
  type?: "info" | "tip" | "warning" | "key" | "question";
  title?: string;
}
const { type = "info", title } = Astro.props;
const styles = {
  info: { icon: "💡", border: "border-sky-300 dark:border-sky-500/40", bg: "bg-sky-50 dark:bg-sky-900/20", label: "Note" },
  tip: { icon: "✅", border: "border-green-300 dark:border-green-500/40", bg: "bg-green-50 dark:bg-green-900/20", label: "Tip" },
  warning: { icon: "⚠️", border: "border-amber-300 dark:border-amber-500/40", bg: "bg-amber-50 dark:bg-amber-900/20", label: "Watch out" },
  key: { icon: "🔑", border: "border-brand-300 dark:border-brand-500/40", bg: "bg-brand-50 dark:bg-brand-900/30", label: "Key idea" },
  question: { icon: "🤔", border: "border-pink-300 dark:border-pink-500/40", bg: "bg-pink-50 dark:bg-pink-900/20", label: "Think about it" },
};
const s = styles[type] ?? styles.info;
---

<aside class={`not-prose my-6 flex gap-3 rounded-xl border ${s.border} ${s.bg} p-4`}>
  <span class="text-xl leading-none" aria-hidden="true">{s.icon}</span>
  <div class="text-sm leading-relaxed text-gray-700 dark:text-gray-200">
    <p class="m-0 mb-1 font-bold text-gray-900 dark:text-white">{title ?? s.label}</p>
    <div class="space-y-2 [&_a]:text-brand-600 [&_a]:underline dark:[&_a]:text-brand-300"><slot /></div>
  </div>
</aside>
