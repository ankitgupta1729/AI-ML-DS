---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { EXAMS } from "../../consts";

const posts = (await getCollection("blog")).filter((p) => !p.data.draft);
const countFor = (slug: string) => posts.filter((p) => (p.data.exams || []).includes(slug)).length;
---

<BaseLayout title="Exam prep" description="Concept explainers, doubt-solving and mock tests for IIT-JEE, GATE, ISI/CMI, NEET, CAT and UPSC.">
  <section class="aurora">
    <div class="mx-auto max-w-3xl px-4 py-16 text-center sm:px-6">
      <h1 class="font-serif text-4xl font-bold text-gray-900 sm:text-5xl dark:text-white">Crack your exam 🎯</h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-gray-600 dark:text-gray-400">
        Clear concept explainers, a community to solve your doubts, and mock tests with instant feedback — everything you need, free, in one place.
      </p>
      <div class="mt-6 flex flex-wrap justify-center gap-3">
        <a href="/doubts" class="rounded-xl bg-brand-600 px-5 py-2.5 font-semibold text-white transition hover:bg-brand-700">💬 Ask a doubt</a>
        <a href="/pyq" class="rounded-xl border border-gray-300 bg-white/70 px-5 py-2.5 font-semibold text-gray-800 backdrop-blur transition hover:border-brand-400 dark:border-white/15 dark:bg-white/5 dark:text-gray-100">📑 Previous-year Qs</a>
        <a href="/mock-tests" class="rounded-xl border border-gray-300 bg-white/70 px-5 py-2.5 font-semibold text-gray-800 backdrop-blur transition hover:border-brand-400 dark:border-white/15 dark:bg-white/5 dark:text-gray-100">📝 Mock tests</a>
        <a href="/exam-alerts" class="rounded-xl border border-gray-300 bg-white/70 px-5 py-2.5 font-semibold text-gray-800 backdrop-blur transition hover:border-brand-400 dark:border-white/15 dark:bg-white/5 dark:text-gray-100">🔔 Exam alerts</a>
        <a href="/prep" class="rounded-xl border border-gray-300 bg-white/70 px-5 py-2.5 font-semibold text-gray-800 backdrop-blur transition hover:border-brand-400 dark:border-white/15 dark:bg-white/5 dark:text-gray-100">🚀 Prep tips</a>
        <a href="/practice" class="rounded-xl border border-gray-300 bg-white/70 px-5 py-2.5 font-semibold text-gray-800 backdrop-blur transition hover:border-brand-400 dark:border-white/15 dark:bg-white/5 dark:text-gray-100">🧠 Revision</a>
        <a href="/resources" class="rounded-xl border border-gray-300 bg-white/70 px-5 py-2.5 font-semibold text-gray-800 backdrop-blur transition hover:border-brand-400 dark:border-white/15 dark:bg-white/5 dark:text-gray-100">📚 Books &amp; lectures</a>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
    <h2 class="mb-6 font-serif text-2xl font-bold text-gray-900 dark:text-white">Choose your exam</h2>
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        EXAMS.map((e) => (
          <a href={`/exams/${e.slug}`} data-reveal class="card-lift group overflow-hidden rounded-2xl border border-gray-200 bg-white p-6 hover:border-brand-300 dark:border-white/10 dark:bg-white/[0.03] dark:hover:border-brand-500/50">
            <div class="flex items-center justify-between">
              <div class="grid h-14 w-14 place-items-center rounded-2xl text-3xl" style={`background:${e.color}1a`}>{e.icon}</div>
              <span class="rounded-full bg-gray-100 px-3 py-1 text-xs font-semibold text-gray-600 dark:bg-white/5 dark:text-gray-300">{countFor(e.slug)} guides</span>
            </div>
            <h3 class="mt-4 text-xl font-bold text-gray-900 dark:text-white">{e.name}</h3>
            <p class="mt-1 text-sm leading-relaxed text-gray-600 dark:text-gray-400">{e.blurb}</p>
            <div class="mt-3 flex flex-wrap gap-1.5">
              {e.subjects.map((s) => <span class="rounded-full bg-gray-100 px-2 py-0.5 text-xs text-gray-500 dark:bg-white/5 dark:text-gray-400">{s}</span>)}
            </div>
            <span class="mt-4 inline-block text-sm font-semibold text-brand-600 transition group-hover:translate-x-0.5 dark:text-brand-300">Open →</span>
          </a>
        ))
      }
    </div>

    <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      <div class="rounded-2xl border border-gray-200 p-6 text-center dark:border-white/10">
        <div class="text-3xl">📖</div><h3 class="mt-2 font-bold text-gray-900 dark:text-white">Learn concepts</h3>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Clear, intuition-first explainers written by the community.</p>
      </div>
      <a href="/pyq" class="card-lift rounded-2xl border border-gray-200 p-6 text-center dark:border-white/10">
        <div class="text-3xl">📑</div><h3 class="mt-2 font-bold text-gray-900 dark:text-white">Previous-year Qs</h3>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">A solved bank of past-paper questions by exam, subject &amp; year.</p>
      </a>
      <div class="rounded-2xl border border-gray-200 p-6 text-center dark:border-white/10">
        <div class="text-3xl">💬</div><h3 class="mt-2 font-bold text-gray-900 dark:text-white">Clear your doubts</h3>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Ask anything; get answers you can vote on and accept.</p>
      </div>
      <a href="/mock-tests" class="card-lift rounded-2xl border border-gray-200 p-6 text-center dark:border-white/10">
        <div class="text-3xl">📝</div><h3 class="mt-2 font-bold text-gray-900 dark:text-white">Test yourself</h3>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Timed mock tests with instant scoring and explanations.</p>
      </a>
    </div>
  </section>
</BaseLayout>
