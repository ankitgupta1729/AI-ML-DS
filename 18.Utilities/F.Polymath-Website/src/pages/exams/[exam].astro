---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ArticleCard from "../../components/ArticleCard.astro";
import { readingTime } from "../../lib/utils";
import { EXAMS } from "../../consts";

export async function getStaticPaths() {
  const posts = (await getCollection("blog")).filter((p) => !p.data.draft);
  return EXAMS.map((exam) => ({
    params: { exam: exam.slug },
    props: {
      exam,
      posts: posts
        .filter((p) => (p.data.exams || []).includes(exam.slug))
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

const { exam, posts } = Astro.props;
---

<BaseLayout title={`${exam.name} prep`} description={exam.blurb}>
  <section class="relative overflow-hidden aurora">
    <div class="relative mx-auto max-w-6xl px-4 py-14 sm:px-6">
      <a href="/exams" class="text-sm font-semibold text-brand-600 hover:underline dark:text-brand-300">← All exams</a>
      <div class="mt-4 flex items-center gap-4">
        <div class="grid h-16 w-16 place-items-center rounded-2xl text-4xl" style={`background:${exam.color}1a`}>{exam.icon}</div>
        <div>
          <h1 class="font-serif text-4xl font-bold text-gray-900 sm:text-5xl dark:text-white">{exam.name}</h1>
          <p class="mt-1 text-lg text-gray-600 dark:text-gray-400">{exam.blurb}</p>
        </div>
      </div>
      <div class="mt-5 flex flex-wrap gap-3">
        <a href={`/doubts?exam=${exam.slug}`} class="rounded-xl bg-brand-600 px-5 py-2.5 font-semibold text-white transition hover:bg-brand-700">💬 Ask a doubt</a>
        <a href={`/pyq?exam=${exam.slug}`} class="rounded-xl border border-gray-300 bg-white px-5 py-2.5 font-semibold text-gray-800 transition hover:border-brand-400 dark:border-white/15 dark:bg-white/5 dark:text-gray-100">📑 Previous-year Qs</a>
        <a href={`/mock-tests?exam=${exam.slug}`} class="rounded-xl border border-gray-300 bg-white px-5 py-2.5 font-semibold text-gray-800 transition hover:border-brand-400 dark:border-white/15 dark:bg-white/5 dark:text-gray-100">📝 Mock tests</a>
        <a href="/exam-alerts" class="rounded-xl border border-gray-300 bg-white px-5 py-2.5 font-semibold text-gray-800 transition hover:border-brand-400 dark:border-white/15 dark:bg-white/5 dark:text-gray-100">🔔 Alerts</a>
        <a href="/prep" class="rounded-xl border border-gray-300 bg-white px-5 py-2.5 font-semibold text-gray-800 transition hover:border-brand-400 dark:border-white/15 dark:bg-white/5 dark:text-gray-100">🚀 Prep tips</a>
        <a href={`/resources?exam=${exam.slug}`} class="rounded-xl border border-gray-300 bg-white px-5 py-2.5 font-semibold text-gray-800 transition hover:border-brand-400 dark:border-white/15 dark:bg-white/5 dark:text-gray-100">📚 Books &amp; lectures</a>
        <a href="/write" class="rounded-xl border border-gray-300 bg-white px-5 py-2.5 font-semibold text-gray-800 transition hover:border-brand-400 dark:border-white/15 dark:bg-white/5 dark:text-gray-100">✍️ Contribute</a>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
    <div class="mb-6 flex flex-wrap gap-2">
      {exam.subjects.map((s) => <span class="rounded-full border border-gray-200 px-3 py-1 text-sm font-medium text-gray-600 dark:border-white/10 dark:text-gray-300">{s}</span>)}
    </div>

    <h2 class="mb-6 font-serif text-2xl font-bold text-gray-900 dark:text-white">Concept guides</h2>
    {
      posts.length > 0 ? (
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {posts.map((p) => (
            <ArticleCard url={`/blog/${p.id}`} title={p.data.title} description={p.data.description} category={p.data.category} pubDate={p.data.pubDate} heroEmoji={p.data.heroEmoji} minutes={readingTime(p.body ?? "")} />
          ))}
        </div>
      ) : (
        <div class="rounded-2xl border border-dashed border-gray-300 p-12 text-center dark:border-white/10">
          <p class="text-4xl">{exam.icon}</p>
          <p class="mt-3 text-lg font-semibold text-gray-800 dark:text-gray-200">No guides yet for {exam.name}</p>
          <p class="mt-1 text-gray-500 dark:text-gray-400">Know this exam well? Be the first to write a concept guide and help thousands of students.</p>
          <a href="/write" class="mt-5 inline-block rounded-xl bg-brand-600 px-5 py-2.5 font-semibold text-white transition hover:bg-brand-700">✍️ Write the first guide</a>
        </div>
      )
    }
  </section>
</BaseLayout>
