---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ArticleCard from "../../components/ArticleCard.astro";
import { readingTime } from "../../lib/utils";
import { CATEGORIES } from "../../consts";

const posts = (await getCollection("blog"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Articles" description="Browse every Polymath article across AI, science, mathematics, finance, history and more.">
  <section class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
    <header class="max-w-2xl">
      <h1 class="font-serif text-4xl font-bold text-gray-900 sm:text-5xl dark:text-white">All articles</h1>
      <p class="mt-3 text-lg text-gray-600 dark:text-gray-400">
        {posts.length} essays and explainers, written to be read by humans. Filter by topic or just start scrolling.
      </p>
    </header>

    <!-- Topic filter -->
    <div class="mt-8 flex flex-wrap gap-2" id="filter-bar">
      <button data-filter="all" class="filter-chip active">All</button>
      {
        CATEGORIES.map((c) => (
          <button data-filter={c.slug} class="filter-chip">{c.icon} {c.name}</button>
        ))
      }
    </div>

    <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3" id="posts-grid">
      {
        posts.map((p) => (
          <div data-category={p.data.category}>
            <ArticleCard
              url={`/blog/${p.id}`}
              title={p.data.title}
              description={p.data.description}
              category={p.data.category}
              pubDate={p.data.pubDate}
              heroEmoji={p.data.heroEmoji}
              tags={p.data.tags}
              minutes={readingTime(p.body ?? "")}
            />
          </div>
        ))
      }
    </div>
    <p id="empty-state" class="mt-10 hidden text-center text-gray-500">No articles in this topic yet — check back soon!</p>
  </section>
</BaseLayout>

<style>
  .filter-chip {
    border-radius: 9999px;
    border: 1px solid rgb(229 231 235);
    padding: 0.4rem 0.9rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: rgb(75 85 99);
    cursor: pointer;
    transition: all 0.15s ease;
  }
  .filter-chip:hover { border-color: #818cf8; }
  .filter-chip.active { background: #4f46e5; border-color: #4f46e5; color: #fff; }
  :global(.dark) .filter-chip { border-color: rgba(255,255,255,0.12); color: rgb(209 213 219); }
  :global(.dark) .filter-chip.active { background: #6366f1; border-color: #6366f1; color: #fff; }
</style>

<script is:inline>
  (function () {
    const chips = document.querySelectorAll(".filter-chip");
    const items = document.querySelectorAll("#posts-grid > [data-category]");
    const empty = document.getElementById("empty-state");
    chips.forEach((chip) => {
      chip.addEventListener("click", () => {
        chips.forEach((c) => c.classList.remove("active"));
        chip.classList.add("active");
        const f = chip.getAttribute("data-filter");
        let shown = 0;
        items.forEach((it) => {
          const ok = f === "all" || it.getAttribute("data-category") === f;
          it.style.display = ok ? "" : "none";
          if (ok) shown++;
        });
        empty?.classList.toggle("hidden", shown > 0);
      });
    });
  })();
</script>
