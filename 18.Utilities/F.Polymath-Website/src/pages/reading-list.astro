---
import BaseLayout from "../layouts/BaseLayout.astro";
import { CATEGORIES } from "../consts";

const colorMap = Object.fromEntries(CATEGORIES.map((c) => [c.slug, c.color]));
const nameMap = Object.fromEntries(CATEGORIES.map((c) => [c.slug, c.name]));
---

<BaseLayout title="Reading list" description="Your saved Polymath articles.">
  <section class="mx-auto max-w-4xl px-4 py-12 sm:px-6">
    <h1 class="font-serif text-4xl font-bold text-gray-900 sm:text-5xl dark:text-white">📚 Your reading list</h1>
    <p class="mt-3 text-lg text-gray-600 dark:text-gray-400">
      Articles you've saved with the “Save for later” button. Stored privately in this browser — no account needed.
    </p>

    <div id="rl-empty" class="mt-10 hidden rounded-2xl border border-dashed border-gray-300 p-12 text-center dark:border-white/10">
      <p class="text-4xl">🔖</p>
      <p class="mt-3 text-lg font-semibold text-gray-800 dark:text-gray-200">Nothing saved yet</p>
      <p class="mt-1 text-gray-500 dark:text-gray-400">Tap “Save for later” on any article and it'll appear here.</p>
      <a href="/blog" class="mt-5 inline-block rounded-xl bg-brand-600 px-5 py-2.5 font-semibold text-white transition hover:bg-brand-700">Browse articles</a>
    </div>

    <div id="rl-list" class="mt-8 grid gap-4 sm:grid-cols-2"></div>
  </section>
</BaseLayout>

<script is:inline define:vars={{ colorMap, nameMap }}>
  (function () {
    var KEY = "reading-list";
    var list = [];
    try { list = JSON.parse(localStorage.getItem(KEY) || "[]"); } catch (e) {}

    var wrap = document.getElementById("rl-list");
    var empty = document.getElementById("rl-empty");

    function save() { localStorage.setItem(KEY, JSON.stringify(list)); }

    function render() {
      wrap.innerHTML = "";
      if (!list.length) { empty.classList.remove("hidden"); return; }
      empty.classList.add("hidden");
      list.forEach(function (item) {
        var color = colorMap[item.category] || "#6366f1";
        var catName = nameMap[item.category] || item.category;
        var card = document.createElement("div");
        card.className =
          "card-lift relative rounded-2xl border border-gray-200 bg-white p-5 dark:border-white/10 dark:bg-white/[0.03]";
        card.innerHTML =
          '<div class="text-3xl">' + (item.emoji || "📖") + "</div>" +
          '<p class="mt-2 text-xs font-semibold" style="color:' + color + '">' + catName + "</p>" +
          '<a href="' + item.url + '" class="mt-1 block font-bold leading-snug text-gray-900 dark:text-white hover:text-brand-600">' +
          item.title + "</a>" +
          '<p class="mt-2 line-clamp-2 text-sm text-gray-600 dark:text-gray-400">' + (item.description || "") + "</p>" +
          '<button data-remove="' + item.id + '" class="mt-3 text-xs font-semibold text-gray-400 hover:text-red-500">Remove ✕</button>';
        wrap.appendChild(card);
      });
      wrap.querySelectorAll("[data-remove]").forEach(function (b) {
        b.addEventListener("click", function () {
          var id = b.getAttribute("data-remove");
          list = list.filter(function (x) { return x.id !== id; });
          save();
          render();
        });
      });
    }
    render();

    // Merge cross-device bookmarks from Supabase when signed in.
    async function syncFromRemote() {
      try {
        var u = window.PolyAuth && window.PolyAuth.user;
        if (!u || !u.id || !window.polyDB) return;
        var sb = await window.polyDB();
        if (!sb) return;
        var res = await sb.from("bookmarks").select("*").eq("user_id", u.id).order("created_at", { ascending: false });
        if (res.error || !res.data) return;
        var have = {};
        list.forEach(function (x) { have[x.id] = true; });
        res.data.forEach(function (r) {
          if (!have[r.slug]) list.push({ id: r.slug, title: r.title, category: r.category, emoji: r.emoji, description: r.description, url: "/blog/" + r.slug + "/" });
        });
        save();
        render();
      } catch (e) {}
    }
    if (window.PolyAuth) window.PolyAuth.onChange(function (u) { if (u) syncFromRemote(); });
    document.addEventListener("polyauth", function (e) { if (e.detail) syncFromRemote(); });
  })();
</script>
