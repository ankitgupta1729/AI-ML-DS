---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SUPABASE } from "../consts";
const live = !!(SUPABASE.url && SUPABASE.anonKey);
---

<BaseLayout title="My posts" description="Your articles on Polymath.">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16/dist/katex.min.css" />

  <section class="mx-auto max-w-3xl px-4 py-10 sm:px-6" data-live={live ? "1" : ""}>
    <div class="mb-6 flex items-center justify-between">
      <h1 class="font-serif text-3xl font-bold text-gray-900 dark:text-white">My posts</h1>
      <a href="/write" class="rounded-lg bg-brand-600 px-4 py-2 text-sm font-semibold text-white transition hover:bg-brand-700">✍️ New article</a>
    </div>

    <div id="mp-gate" class="hidden rounded-2xl border border-dashed border-gray-300 p-12 text-center dark:border-white/10">
      <p class="text-4xl">📝</p>
      <p class="mt-3 text-lg font-semibold text-gray-800 dark:text-gray-200">Sign in to see your posts</p>
      <button id="mp-signin" class="mt-4 rounded-xl bg-brand-600 px-5 py-2.5 font-semibold text-white transition hover:bg-brand-700">Sign in</button>
    </div>

    <div id="mp-skeleton" class="hidden space-y-4">
      {[0, 1].map(() => (
        <div class="rounded-2xl border border-gray-200 p-5 dark:border-white/10">
          <div class="skeleton h-7 w-7 rounded-full"></div>
          <div class="skeleton mt-2 h-5 w-2/3"></div>
          <div class="skeleton mt-2 h-3 w-32"></div>
        </div>
      ))}
    </div>
    <div id="mp-list" class="space-y-4"></div>
    <p id="mp-empty" class="hidden rounded-2xl border border-dashed border-gray-300 p-10 text-center text-gray-500 dark:border-white/10">No posts yet. <a href="/write" class="font-semibold text-brand-600">Write your first →</a></p>

    <!-- Reader -->
    <div id="mp-reader" class="hidden">
      <button id="mp-back" class="mb-4 text-sm font-semibold text-brand-600 hover:underline dark:text-brand-300">← Back to my posts</button>
      <article id="mp-article" class="prose prose-lg max-w-none dark:prose-invert"></article>
    </div>
  </section>
</BaseLayout>

<script is:inline define:vars={{ live, url: SUPABASE.url, key: SUPABASE.anonKey }}>
  (function () {
    const gate = document.getElementById("mp-gate");
    const listEl = document.getElementById("mp-list");
    const emptyEl = document.getElementById("mp-empty");
    const reader = document.getElementById("mp-reader");
    const articleEl = document.getElementById("mp-article");
    document.getElementById("mp-signin").addEventListener("click", () => window.PolyAuth && window.PolyAuth.openModal());
    document.getElementById("mp-back").addEventListener("click", () => { reader.classList.add("hidden"); listEl.classList.remove("hidden"); });

    let _libs = null;
    async function libs() {
      if (_libs) return _libs;
      const [m, d, k] = await Promise.all([import("https://esm.sh/marked@12"), import("https://esm.sh/dompurify@3"), import("https://esm.sh/katex@0.16")]);
      _libs = { marked: m.marked, DOMPurify: d.default, katex: k.default };
      return _libs;
    }
    async function render(src) {
      const { marked, DOMPurify, katex } = await libs();
      const store = []; const stash = (h) => { store.push(h); return " B" + (store.length - 1) + " "; };
      src = src.replace(/\$\$([\s\S]+?)\$\$/g, (m, x) => { try { return stash(katex.renderToString(x.trim(), { displayMode: true, output: "html", throwOnError: false })); } catch (e) { return m; } });
      src = src.replace(/\$([^\$\n]+?)\$/g, (m, x) => { try { return stash(katex.renderToString(x.trim(), { output: "html", throwOnError: false })); } catch (e) { return m; } });
      let html = marked.parse(src, { breaks: true }).replace(/ B(\d+) /g, (m, i) => store[+i]);
      return DOMPurify.sanitize(html, { ADD_TAGS: ["span"], ADD_ATTR: ["class", "style", "aria-hidden"] });
    }
    const esc = (s) => (s || "").replace(/[&<>"']/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[c]));
    const fmt = (iso) => { try { return new Date(iso).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" }); } catch (e) { return ""; } };

    async function getPosts(user) {
      if (live) {
        try {
          const { createClient } = await import("https://esm.sh/@supabase/supabase-js@2");
          const sb = createClient(url, key);
          await sb.auth.getSession(); // ensure the signed-in JWT is attached for RLS
          const { data } = await sb.from("user_posts").select("*").eq("author_id", user.id).order("created_at", { ascending: false });
          return (data || []).map((r) => ({ id: r.id, title: r.title, emoji: r.emoji, category: r.category, body: r.body, createdAt: r.created_at, published: r.published }));
        } catch (e) { return []; }
      }
      try { return JSON.parse(localStorage.getItem("polyPosts") || "[]"); } catch (e) { return []; }
    }

    async function del(id) {
      if (live) {
        try { const { createClient } = await import("https://esm.sh/@supabase/supabase-js@2"); const sb = createClient(url, key); await sb.from("user_posts").delete().eq("id", id); } catch (e) {}
      } else {
        let arr = []; try { arr = JSON.parse(localStorage.getItem("polyPosts") || "[]"); } catch (e) {}
        localStorage.setItem("polyPosts", JSON.stringify(arr.filter((p) => p.id !== id)));
      }
    }

    let posts = [];
    const skeletonEl = document.getElementById("mp-skeleton");
    async function load(user) {
      gate.classList.toggle("hidden", !!user);
      listEl.classList.toggle("hidden", !user);
      if (!user) { emptyEl.classList.add("hidden"); skeletonEl.classList.add("hidden"); return; }
      skeletonEl.classList.remove("hidden");
      posts = await getPosts(user);
      skeletonEl.classList.add("hidden");
      emptyEl.classList.toggle("hidden", posts.length > 0);
      listEl.innerHTML = posts.map((p) =>
        '<div class="rounded-2xl border border-gray-200 bg-white p-5 dark:border-white/10 dark:bg-white/[0.03]">' +
          '<div class="flex items-start justify-between gap-3">' +
            '<div><div class="text-2xl">' + (p.emoji || "📝") + '</div>' +
            '<h3 class="mt-1 text-lg font-bold text-gray-900 dark:text-white">' + esc(p.title) + '</h3>' +
            '<p class="mt-1 text-xs text-gray-400">' + (p.published ? "Published" : "Draft") + " · " + fmt(p.createdAt) + '</p></div>' +
            '<span class="rounded-full px-2 py-0.5 text-xs font-medium ' + (p.published ? "bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-300" : "bg-gray-100 text-gray-500 dark:bg-white/5") + '">' + (p.published ? "live" : "draft") + '</span>' +
          '</div>' +
          '<div class="mt-3 flex gap-3 text-sm font-semibold">' +
            '<button data-read="' + p.id + '" class="text-brand-600 hover:underline dark:text-brand-300">Read</button>' +
            '<button data-del="' + p.id + '" class="text-gray-400 hover:text-red-500">Delete</button>' +
          '</div>' +
        '</div>'
      ).join("");
      listEl.querySelectorAll("[data-read]").forEach((b) => b.addEventListener("click", () => openReader(b.getAttribute("data-read"))));
      listEl.querySelectorAll("[data-del]").forEach((b) => b.addEventListener("click", async () => { if (confirm("Delete this post?")) { await del(b.getAttribute("data-del")); load(window.PolyAuth && window.PolyAuth.user); } }));
    }

    async function openReader(id) {
      const p = posts.find((x) => x.id === id);
      if (!p) return;
      listEl.classList.add("hidden");
      reader.classList.remove("hidden");
      articleEl.innerHTML = '<h1>' + esc(p.title) + '</h1>' + (await render(p.body));
      if (window.polyHighlight) window.polyHighlight(articleEl);
      window.scrollTo({ top: 0, behavior: "smooth" });
    }

    if (window.PolyAuth) window.PolyAuth.onChange(load);
    document.addEventListener("polyauth", (e) => load(e.detail));
  })();
</script>
