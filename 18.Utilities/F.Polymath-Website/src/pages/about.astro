---
import BaseLayout from "../layouts/BaseLayout.astro";
import SocialLinks from "../components/SocialLinks.astro";
import { SITE } from "../consts";

const principles = [
  { icon: "🎓", title: "Learning first", text: "Every article is written to genuinely teach — clear, honest, and free of fluff. If it doesn't help you understand, it doesn't belong here." },
  { icon: "🆓", title: "Free forever", text: "No paywalls, no ads, no trackers. Built on free, open infrastructure so it can last for decades at zero cost." },
  { icon: "🗣️", title: "Open discussion", text: "Disagreement is welcome — done with respect. Reactions, comments and a forum turn reading into conversation." },
  { icon: "🌍", title: "For everyone", text: "Knowledge should be accessible. Fast on any device, readable in light or dark, and friendly to screen readers." },
];
---

<BaseLayout title="About" description="What Polymath is, why it exists, and how it works.">
  <section class="aurora">
    <div class="mx-auto max-w-3xl px-4 py-16 sm:px-6">
      <h1 class="font-serif text-4xl font-bold text-gray-900 sm:text-5xl dark:text-white">About {SITE.name}</h1>
      <p class="mt-4 text-lg leading-relaxed text-gray-700 dark:text-gray-300">
        A <em>polymath</em> is someone whose curiosity refuses to stay in one lane. This site is built for exactly that
        instinct — a single, beautiful home for ideas across artificial intelligence, mathematics, physics, finance,
        history, and everything in between.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-4 py-12 sm:px-6">
    <div class="prose prose-lg max-w-none dark:prose-invert">
      <h2>Why it exists</h2>
      <p>
        The best explanations on the internet are scattered across dozens of sites, half of them behind paywalls or
        buried under ads. {SITE.name} is an attempt to collect deep, readable explainers in one calm place — and to
        let readers talk back. Reading should be the start of a conversation, not the end of one.
      </p>
      <h2>How it works</h2>
      <p>
        The site is a static website built with <a href="https://astro.build">Astro</a> and styled with Tailwind CSS.
        It's hosted free on GitHub Pages, search runs in your browser via Pagefind, and discussion is powered by
        GitHub Discussions through Giscus. That stack means it's fast, reliable, scalable to large traffic, and costs
        nothing to keep online.
      </p>
    </div>

    <div class="mt-10 grid gap-5 sm:grid-cols-2">
      {
        principles.map((p) => (
          <div data-reveal class="rounded-2xl border border-gray-200 bg-white p-6 dark:border-white/10 dark:bg-white/[0.03]">
            <div class="text-3xl">{p.icon}</div>
            <h3 class="mt-3 text-lg font-bold text-gray-900 dark:text-white">{p.title}</h3>
            <p class="mt-1 text-sm leading-relaxed text-gray-600 dark:text-gray-400">{p.text}</p>
          </div>
        ))
      }
    </div>

    <div class="mt-12 rounded-2xl border border-gray-200 bg-white p-6 dark:border-white/10 dark:bg-white/[0.03]">
      <h2 class="text-xl font-bold text-gray-900 dark:text-white">Curated by {SITE.author}</h2>
      <p class="mt-2 text-gray-600 dark:text-gray-400">
        Built and maintained as an open project. Want to contribute an article, fix a typo, or suggest a topic?
        Everything lives on GitHub — pull requests and ideas are warmly welcome.
      </p>
      <div class="mt-5"><SocialLinks /></div>
    </div>
  </section>
</BaseLayout>
