---
import BaseLayout from "../layouts/BaseLayout.astro";
import MemoryMatch from "../components/widgets/MemoryMatch.astro";
import ReactionTest from "../components/widgets/ReactionTest.astro";
import MathDrill from "../components/widgets/MathDrill.astro";
import GameOfLife from "../components/widgets/GameOfLife.astro";
import MontyHall from "../components/widgets/MontyHall.astro";
import DoublePendulum from "../components/widgets/DoublePendulum.astro";
import Mandelbrot from "../components/widgets/Mandelbrot.astro";
import SortVisualizer from "../components/widgets/SortVisualizer.astro";
import BrainTeaser from "../components/BrainTeaser.astro";
---

<BaseLayout title="Arcade" description="Take a brain break — fun games and playful simulations for curious minds.">
  <section class="aurora">
    <div class="mx-auto max-w-3xl px-4 py-14 text-center sm:px-6">
      <h1 class="font-serif text-4xl font-bold text-gray-900 sm:text-5xl dark:text-white">The Arcade 🎮</h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-gray-600 dark:text-gray-400">
        Study hard, play harder. A few quick games and toys to sharpen your brain and unwind between problem sets.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-5xl px-4 py-10 sm:px-6">
    <div class="mb-6">
      <BrainTeaser />
    </div>
    <div class="grid gap-6 lg:grid-cols-2">
      <MathDrill />
      <ReactionTest />
      <MemoryMatch />
      <div class="rounded-2xl border border-gray-200 bg-white p-5 shadow-sm dark:border-white/10 dark:bg-white/[0.03]">
        <h4 class="m-0 mb-3 flex items-center gap-2 font-bold text-gray-900 dark:text-white"><span class="text-xl">🚪</span> Beat the odds</h4>
        <p class="m-0 text-sm text-gray-600 dark:text-gray-400">The classic Monty Hall game — can you outsmart probability?</p>
      </div>
    </div>

    <div class="mt-6">
      <MontyHall />
    </div>

    <h2 class="mb-2 mt-8 font-serif text-2xl font-bold text-gray-900 dark:text-white">🌀 Mesmerising simulations</h2>
    <p class="mb-2 text-gray-600 dark:text-gray-400">Chaos and infinity, rendered live. Nudge the pendulum, or click into the Mandelbrot set forever.</p>
    <div class="grid gap-6 lg:grid-cols-2">
      <DoublePendulum />
      <Mandelbrot />
      <SortVisualizer />
    </div>

    <h2 class="mb-2 mt-8 font-serif text-2xl font-bold text-gray-900 dark:text-white">🦠 Sandbox: Conway's Game of Life</h2>
    <p class="mb-2 text-gray-600 dark:text-gray-400">A mesmerising toy where simple rules create endless emergent patterns. Draw, drop a glider gun, and watch.</p>
    <GameOfLife />

    <div class="mt-10 rounded-3xl border border-brand-200/50 bg-gradient-to-br from-brand-50 to-pink-50 p-8 text-center dark:border-white/10 dark:from-brand-900/30 dark:to-pink-900/20">
      <h2 class="font-serif text-2xl font-bold text-gray-900 dark:text-white">Curiosity recharged?</h2>
      <p class="mx-auto mt-2 max-w-xl text-gray-700 dark:text-gray-300">Channel that energy — explore the great unsolved problems, or get back to crushing mock tests.</p>
      <div class="mt-5 flex flex-wrap justify-center gap-3">
        <a href="/frontiers" class="rounded-xl bg-brand-600 px-5 py-2.5 font-semibold text-white transition hover:bg-brand-700">🚀 Open Frontiers</a>
        <a href="/mock-tests" class="rounded-xl border border-gray-300 bg-white px-5 py-2.5 font-semibold text-gray-800 transition hover:border-brand-400 dark:border-white/15 dark:bg-white/5 dark:text-gray-100">📝 Mock tests</a>
      </div>
    </div>
  </section>
</BaseLayout>
