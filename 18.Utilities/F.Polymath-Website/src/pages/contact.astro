---
import BaseLayout from "../layouts/BaseLayout.astro";
import SocialLinks from "../components/SocialLinks.astro";
import { SITE, SOCIAL } from "../consts";

const repo = "ankitgupta1729/ankitgupta1729.github.io";
const discussionsUrl = "/forum";
const issuesUrl = `https://github.com/${repo}/issues/new`;
---

<BaseLayout title="Contact" description="Get in touch, give feedback, or report an issue.">
  <section class="mx-auto max-w-3xl px-4 py-16 sm:px-6">
    <h1 class="font-serif text-4xl font-bold text-gray-900 sm:text-5xl dark:text-white">Say hello</h1>
    <p class="mt-4 text-lg text-gray-600 dark:text-gray-400">
      Feedback, corrections, ideas, collaboration — all welcome. Pick whichever channel suits you.
    </p>

    <div class="mt-10 grid gap-5 sm:grid-cols-2">
      <a href={`mailto:${SITE.email}`} class="card-lift rounded-2xl border border-gray-200 bg-white p-6 hover:border-brand-300 dark:border-white/10 dark:bg-white/[0.03] dark:hover:border-brand-500/50">
        <div class="text-3xl">✉️</div>
        <h2 class="mt-3 font-bold text-gray-900 dark:text-white">Email</h2>
        <p class="mt-1 text-sm text-gray-600 dark:text-gray-400">{SITE.email}</p>
      </a>
      <a href={discussionsUrl} target="_blank" rel="noopener" class="card-lift rounded-2xl border border-gray-200 bg-white p-6 hover:border-brand-300 dark:border-white/10 dark:bg-white/[0.03] dark:hover:border-brand-500/50">
        <div class="text-3xl">💬</div>
        <h2 class="mt-3 font-bold text-gray-900 dark:text-white">Discuss</h2>
        <p class="mt-1 text-sm text-gray-600 dark:text-gray-400">Ask or share in the public forum.</p>
      </a>
      <a href={issuesUrl} target="_blank" rel="noopener" class="card-lift rounded-2xl border border-gray-200 bg-white p-6 hover:border-brand-300 dark:border-white/10 dark:bg-white/[0.03] dark:hover:border-brand-500/50">
        <div class="text-3xl">🐛</div>
        <h2 class="mt-3 font-bold text-gray-900 dark:text-white">Report an issue</h2>
        <p class="mt-1 text-sm text-gray-600 dark:text-gray-400">Found a bug or a factual error? Open a GitHub issue.</p>
      </a>
      <div class="rounded-2xl border border-gray-200 bg-white p-6 dark:border-white/10 dark:bg-white/[0.03]">
        <div class="text-3xl">🔗</div>
        <h2 class="mt-3 font-bold text-gray-900 dark:text-white">Social</h2>
        <p class="mt-1 mb-3 text-sm text-gray-600 dark:text-gray-400">Follow along for new articles.</p>
        <SocialLinks />
      </div>
    </div>
  </section>
</BaseLayout>
