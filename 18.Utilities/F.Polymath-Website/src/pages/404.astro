---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Page not found">
  <section class="mx-auto flex max-w-xl flex-col items-center px-4 py-28 text-center sm:px-6">
    <p class="font-serif text-8xl font-bold text-gradient">404</p>
    <h1 class="mt-4 text-2xl font-bold text-gray-900 dark:text-white">This page wandered off exploring.</h1>
    <p class="mt-3 text-gray-600 dark:text-gray-400">
      The link may be broken or the page may have moved. Let's get you back to learning.
    </p>
    <div class="mt-7 flex flex-wrap justify-center gap-3">
      <a href="/" class="rounded-xl bg-brand-600 px-5 py-2.5 font-semibold text-white transition hover:bg-brand-700">Go home</a>
      <a href="/blog" class="rounded-xl border border-gray-300 px-5 py-2.5 font-semibold text-gray-800 transition hover:border-brand-400 dark:border-white/15 dark:text-gray-100">Browse articles</a>
      <a href="/search" class="rounded-xl border border-gray-300 px-5 py-2.5 font-semibold text-gray-800 transition hover:border-brand-400 dark:border-white/15 dark:text-gray-100">Search</a>
    </div>
  </section>
</BaseLayout>
