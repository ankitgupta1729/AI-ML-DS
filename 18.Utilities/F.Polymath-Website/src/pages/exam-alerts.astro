---
import BaseLayout from "../layouts/BaseLayout.astro";
import { EXAM_ALERTS } from "../lib/examAlerts";

const cats = [...new Set(EXAM_ALERTS.map((e) => e.category))];
const catColor: Record<string, string> = {
  Engineering: "#6366f1", Medical: "#22c55e", Management: "#ec4899",
  Research: "#0ea5e9", "Civil Services": "#a16207", Science: "#8b5cf6",
};
const fmt = (iso: string) => iso ? new Date(iso).toLocaleDateString("en-IN", { day: "numeric", month: "short", year: "numeric" }) : "Rolling";
---

<BaseLayout title="Exam alerts & notifications" description="Upcoming Indian technical and competitive exams — dates, application deadlines, eligibility and official links, with live countdowns.">
  <section class="aurora">
    <div class="mx-auto max-w-4xl px-4 py-12 text-center sm:px-6">
      <h1 class="font-serif text-4xl font-bold text-gray-900 sm:text-5xl dark:text-white">Exam alerts 🔔</h1>
      <p class="mx-auto mt-3 max-w-2xl text-lg text-gray-600 dark:text-gray-400">
        Never miss a deadline. Application windows, exam dates, eligibility and official links for India's top technical & competitive exams — with live countdowns.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-5xl px-4 py-8 sm:px-6">
    <div class="mb-5 rounded-xl border border-amber-300 bg-amber-50 px-4 py-3 text-sm text-amber-800 dark:border-amber-500/40 dark:bg-amber-900/20 dark:text-amber-300">
      ⚠️ Dates are <b>indicative</b> (based on each exam's usual cycle). Always confirm on the official website before acting.
    </div>

    <div id="ea-filter" class="mb-6 flex flex-wrap gap-2">
      <button data-filter="all" class="filter-chip active">All</button>
      {cats.map((c) => <button data-filter={c} class="filter-chip">{c}</button>)}
    </div>

    <div id="ea-list" class="grid gap-5 sm:grid-cols-2">
      {
        EXAM_ALERTS.map((e) => (
          <div data-exam data-cat={e.category} data-exam-date={e.examDate} data-apply-start={e.applyStart} data-apply-end={e.applyEnd}
            class="card-lift flex flex-col rounded-2xl border border-gray-200 bg-white p-5 dark:border-white/10 dark:bg-white/[0.03]">
            <div class="flex items-start justify-between gap-2">
              <div>
                <h3 class="text-lg font-bold text-gray-900 dark:text-white">{e.name}</h3>
                <p class="text-xs text-gray-500 dark:text-gray-400">{e.org} · {e.level}</p>
              </div>
              <span class="shrink-0 rounded-full px-2.5 py-0.5 text-xs font-semibold" style={`background:${catColor[e.category]}1a;color:${catColor[e.category]}`}>{e.category}</span>
            </div>

            <div data-status class="mt-3"></div>

            <dl class="mt-3 space-y-1.5 text-sm">
              <div class="flex justify-between gap-2"><dt class="text-gray-500">📝 Apply window</dt><dd class="text-right font-medium text-gray-800 dark:text-gray-200">{fmt(e.applyStart)} – {fmt(e.applyEnd)}</dd></div>
              <div class="flex justify-between gap-2"><dt class="text-gray-500">🗓️ Exam date</dt><dd class="text-right font-medium text-gray-800 dark:text-gray-200">{fmt(e.examDate)}</dd></div>
              <div class="flex justify-between gap-2"><dt class="text-gray-500">🎓 Eligibility</dt><dd class="text-right text-gray-600 dark:text-gray-400">{e.eligibility}</dd></div>
              <div class="flex justify-between gap-2"><dt class="text-gray-500">💳 Fee</dt><dd class="text-right text-gray-600 dark:text-gray-400">{e.fee}</dd></div>
              <div class="flex justify-between gap-2"><dt class="text-gray-500">🖥️ Mode</dt><dd class="text-right text-gray-600 dark:text-gray-400">{e.mode}</dd></div>
            </dl>

            <a href={e.link} target="_blank" rel="noopener" class="mt-4 rounded-xl bg-brand-600 px-4 py-2 text-center text-sm font-semibold text-white transition hover:bg-brand-700">Official website ↗</a>
          </div>
        ))
      }
    </div>
    <p id="ea-empty" class="hidden py-10 text-center text-gray-500">No exams in this category.</p>
  </section>
</BaseLayout>

<script is:inline>
  (function () {
    const DAY = 86400000;
    function daysBetween(a, b) { return Math.ceil((b - a) / DAY); }
    const now = Date.now();

    document.querySelectorAll("[data-exam]").forEach((card) => {
      const exam = card.getAttribute("data-exam-date");
      const aS = card.getAttribute("data-apply-start"), aE = card.getAttribute("data-apply-end");
      const examT = exam ? new Date(exam).getTime() : 0;
      const startT = aS ? new Date(aS).getTime() : 0, endT = aE ? new Date(aE).getTime() : 0;
      let badge = "", color = "#64748b", note = "";
      if (!exam) { badge = "Open year-round"; color = "#0ea5e9"; }
      else if (now < startT) { badge = "Notification soon"; color = "#64748b"; note = "Applications open in " + daysBetween(now, startT) + " days"; }
      else if (now <= endT) { badge = "Applications OPEN"; color = "#22c55e"; note = "⏳ " + daysBetween(now, endT) + " days left to apply"; }
      else if (now < examT) { badge = "Apply closed"; color = "#f59e0b"; note = "🗓️ Exam in " + daysBetween(now, examT) + " days"; }
      else { badge = "Concluded"; color = "#94a3b8"; }
      card.querySelector("[data-status]").innerHTML =
        '<span class="inline-block rounded-full px-2.5 py-1 text-xs font-bold" style="background:' + color + '1a;color:' + color + '">' + badge + "</span>" +
        (note ? '<span class="ml-2 text-xs font-semibold text-gray-600 dark:text-gray-300">' + note + "</span>" : "");
      // sort key
      card.dataset.sort = (!exam ? 9e15 : (now > examT ? 8e15 + examT : examT));
    });

    // sort soonest first (concluded + rolling last)
    const list = document.getElementById("ea-list");
    [...list.children].sort((a, b) => (+a.dataset.sort) - (+b.dataset.sort)).forEach((c) => list.appendChild(c));

    // filter
    const chips = document.querySelectorAll("#ea-filter .filter-chip");
    const empty = document.getElementById("ea-empty");
    chips.forEach((chip) => chip.addEventListener("click", () => {
      chips.forEach((c) => c.classList.remove("active")); chip.classList.add("active");
      const f = chip.getAttribute("data-filter"); let shown = 0;
      document.querySelectorAll("[data-exam]").forEach((c) => { const ok = f === "all" || c.getAttribute("data-cat") === f; c.style.display = ok ? "" : "none"; if (ok) shown++; });
      empty.classList.toggle("hidden", shown > 0);
    }));
  })();
</script>
