---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { CATEGORIES } from "../../consts";

const posts = (await getCollection("blog")).filter((p) => !p.data.draft);
const countFor = (slug: string) => posts.filter((p) => p.data.category === slug).length;
---

<BaseLayout title="Topics" description="Explore every knowledge domain on Polymath.">
  <section class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
    <header class="max-w-2xl">
      <h1 class="font-serif text-4xl font-bold text-gray-900 sm:text-5xl dark:text-white">Topics</h1>
      <p class="mt-3 text-lg text-gray-600 dark:text-gray-400">
        From the foundations of mathematics to the frontier of AI. Each topic is a living collection that grows over time.
      </p>
    </header>

    <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        CATEGORIES.map((c) => (
          <a
            href={`/categories/${c.slug}`}
            data-reveal
            class="card-lift group overflow-hidden rounded-2xl border border-gray-200 bg-white p-6 hover:border-brand-300 dark:border-white/10 dark:bg-white/[0.03] dark:hover:border-brand-500/50"
          >
            <div class="flex items-center justify-between">
              <div class="grid h-14 w-14 place-items-center rounded-2xl text-3xl" style={`background:${c.color}1a`}>
                {c.icon}
              </div>
              <span class="rounded-full bg-gray-100 px-3 py-1 text-xs font-semibold text-gray-600 dark:bg-white/5 dark:text-gray-300">
                {countFor(c.slug)} articles
              </span>
            </div>
            <h2 class="mt-4 text-xl font-bold text-gray-900 dark:text-white">{c.name}</h2>
            <p class="mt-2 text-sm leading-relaxed text-gray-600 dark:text-gray-400">{c.blurb}</p>
            <span class="mt-4 inline-block text-sm font-semibold text-brand-600 transition group-hover:translate-x-0.5 dark:text-brand-300">Browse →</span>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
