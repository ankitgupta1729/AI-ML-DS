---
import BaseLayout from "../layouts/BaseLayout.astro";
import CommentBox from "../components/CommentBox.astro";

const rooms = [
  { icon: "🤖", name: "AI & ML", desc: "Models, papers, agents, and where the field is heading." },
  { icon: "∑", name: "Math & Proofs", desc: "Puzzles, proofs, and elegant problem-solving." },
  { icon: "💹", name: "Finance & Markets", desc: "Quant ideas, economics, and personal finance." },
  { icon: "🔬", name: "Science & Physics", desc: "From quantum weirdness to biology breakthroughs." },
  { icon: "🏛️", name: "History & Society", desc: "Lessons from the past; debates about the present." },
  { icon: "💡", name: "Show & Tell", desc: "Share projects, ask for feedback, find collaborators." },
];
---

<BaseLayout title="Forum" description="Discuss ideas across every topic with the Polymath community.">
  <section class="aurora">
    <div class="mx-auto max-w-4xl px-4 py-16 text-center sm:px-6">
      <h1 class="font-serif text-4xl font-bold text-gray-900 sm:text-5xl dark:text-white">The Forum</h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-gray-600 dark:text-gray-400">
        A calm corner of the internet to ask questions, share what you're learning, and respectfully argue about ideas.
        No ads, no algorithm — just good conversation.
      </p>
      <div class="mt-6 flex flex-wrap justify-center gap-3">
        <a href="#wall" class="rounded-xl bg-brand-600 px-6 py-3 font-semibold text-white transition hover:bg-brand-700">Jump to the wall ↓</a>
        <a href="/community" class="rounded-xl border border-gray-300 bg-white/70 px-6 py-3 font-semibold text-gray-800 backdrop-blur transition hover:border-brand-400 dark:border-white/15 dark:bg-white/5 dark:text-gray-100">Meet the community</a>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
    <h2 class="mb-6 font-serif text-2xl font-bold text-gray-900 dark:text-white">Discussion rooms</h2>
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        rooms.map((r) => (
          <a href="#wall" data-reveal class="card-lift rounded-2xl border border-gray-200 bg-white p-6 hover:border-brand-300 dark:border-white/10 dark:bg-white/[0.03] dark:hover:border-brand-500/50">
            <div class="text-3xl">{r.icon}</div>
            <h3 class="mt-3 text-lg font-bold text-gray-900 dark:text-white">{r.name}</h3>
            <p class="mt-1 text-sm text-gray-600 dark:text-gray-400">{r.desc}</p>
          </a>
        ))
      }
    </div>

    <div id="wall" class="mt-12 scroll-mt-24">
      <CommentBox slug="general" heading="📣 Community wall" />
    </div>
  </section>
</BaseLayout>
