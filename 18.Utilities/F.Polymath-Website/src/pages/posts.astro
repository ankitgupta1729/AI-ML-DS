---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SUPABASE, CATEGORIES } from "../consts";
const live = !!(SUPABASE.url && SUPABASE.anonKey);
const colorMap = Object.fromEntries(CATEGORIES.map((c) => [c.slug, c.color]));
const nameMap = Object.fromEntries(CATEGORIES.map((c) => [c.slug, c.name]));
---

<BaseLayout title="Community posts" description="Articles written and published by the Polymath community.">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16/dist/katex.min.css" />

  <section class="aurora">
    <div class="mx-auto max-w-4xl px-4 py-14 text-center sm:px-6">
      <h1 class="font-serif text-4xl font-bold text-gray-900 sm:text-5xl dark:text-white">Community posts</h1>
      <p class="mx-auto mt-3 max-w-2xl text-lg text-gray-600 dark:text-gray-400">
        Knowledge shared by readers like you. Anyone can write — sign in and publish your own.
      </p>
      <a href="/write" class="mt-5 inline-block rounded-xl bg-brand-600 px-5 py-2.5 font-semibold text-white transition hover:bg-brand-700">✍️ Write an article</a>
    </div>
  </section>

  <section class="mx-auto max-w-4xl px-4 py-12 sm:px-6" data-live={live ? "1" : ""}>
    <p id="pf-empty" class="hidden rounded-2xl border border-dashed border-gray-300 p-12 text-center text-gray-500 dark:border-white/10">
      No community posts yet. <a href="/write" class="font-semibold text-brand-600">Be the first to publish →</a>
    </p>
    <div id="pf-filter" class="mb-6 hidden flex-wrap gap-2">
      <button data-filter="all" class="filter-chip active">All</button>
      {CATEGORIES.map((c) => <button data-filter={c.slug} class="filter-chip">{c.icon} {c.name}</button>)}
    </div>
    <div id="pf-skeleton" class="grid gap-5 sm:grid-cols-2">
      {[0, 1, 2, 3].map(() => (
        <div class="rounded-2xl border border-gray-200 p-5 dark:border-white/10">
          <div class="skeleton h-5 w-20"></div>
          <div class="skeleton mt-3 h-8 w-8 rounded-full"></div>
          <div class="skeleton mt-2 h-5 w-3/4"></div>
          <div class="skeleton mt-3 h-3 w-full"></div>
          <div class="skeleton mt-1.5 h-3 w-5/6"></div>
          <div class="skeleton mt-4 h-7 w-7 rounded-full"></div>
        </div>
      ))}
    </div>
    <div id="pf-list" class="grid gap-5 sm:grid-cols-2"></div>

    <!-- Reader -->
    <div id="pf-reader" class="hidden">
      <button id="pf-back" class="mb-4 text-sm font-semibold text-brand-600 hover:underline dark:text-brand-300">← Back to all posts</button>
      <article id="pf-article" class="prose prose-lg max-w-none dark:prose-invert"></article>
    </div>
  </section>
</BaseLayout>

<script is:inline define:vars={{ live, url: SUPABASE.url, key: SUPABASE.anonKey, colorMap, nameMap }}>
  (function () {
    const listEl = document.getElementById("pf-list");
    const loadingEl = document.getElementById("pf-skeleton");
    const emptyEl = document.getElementById("pf-empty");
    const reader = document.getElementById("pf-reader");
    const articleEl = document.getElementById("pf-article");
    const section = document.querySelector("[data-live]");
    document.getElementById("pf-back").addEventListener("click", () => { reader.classList.add("hidden"); listEl.classList.remove("hidden"); });

    const dice = (s) => "https://api.dicebear.com/9.x/thumbs/svg?seed=" + encodeURIComponent(s || "anon") + "&radius=50";
    const esc = (s) => (s || "").replace(/[&<>"']/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[c]));
    const fmt = (iso) => { try { return new Date(iso).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" }); } catch (e) { return ""; } };
    const excerpt = (md) => esc((md || "").replace(/[#*_`>$\-]/g, "").replace(/\n+/g, " ").trim().slice(0, 150)) + "…";

    let _libs = null;
    async function libs() {
      if (_libs) return _libs;
      const [m, d, k] = await Promise.all([import("https://esm.sh/marked@12"), import("https://esm.sh/dompurify@3"), import("https://esm.sh/katex@0.16")]);
      _libs = { marked: m.marked, DOMPurify: d.default, katex: k.default };
      return _libs;
    }
    async function render(src) {
      const { marked, DOMPurify, katex } = await libs();
      const store = []; const stash = (h) => { store.push(h); return " B" + (store.length - 1) + " "; };
      src = src.replace(/\$\$([\s\S]+?)\$\$/g, (m, x) => { try { return stash(katex.renderToString(x.trim(), { displayMode: true, output: "html", throwOnError: false })); } catch (e) { return m; } });
      src = src.replace(/\$([^\$\n]+?)\$/g, (m, x) => { try { return stash(katex.renderToString(x.trim(), { output: "html", throwOnError: false })); } catch (e) { return m; } });
      let html = marked.parse(src, { breaks: true }).replace(/ B(\d+) /g, (m, i) => store[+i]);
      return DOMPurify.sanitize(html, { ADD_TAGS: ["span"], ADD_ATTR: ["class", "style", "aria-hidden"] });
    }

    let posts = [];
    async function load() {
      if (!live) { loadingEl.classList.add("hidden"); emptyEl.classList.remove("hidden"); emptyEl.innerHTML = "Community publishing turns on once Supabase is connected."; return; }
      try {
        const m = await import("https://esm.sh/@supabase/supabase-js@2");
        const sb = m.createClient(url, key);
        const { data, error } = await sb.from("user_posts").select("*").eq("published", true).order("created_at", { ascending: false });
        loadingEl.classList.add("hidden");
        if (error) { emptyEl.classList.remove("hidden"); emptyEl.textContent = "Couldn't load posts."; return; }
        posts = data || [];
        if (!posts.length) { emptyEl.classList.remove("hidden"); return; }
        document.getElementById("pf-filter").classList.remove("hidden");
        document.getElementById("pf-filter").classList.add("flex");
        listEl.innerHTML = posts.map((p) => {
          const color = colorMap[p.category] || "#6366f1";
          const cat = nameMap[p.category] || p.category || "";
          return (
            '<article data-cat="' + (p.category || "") + '" class="card-lift flex flex-col rounded-2xl border border-gray-200 bg-white p-5 dark:border-white/10 dark:bg-white/[0.03]">' +
              '<div class="flex items-center gap-2 text-xs"><span class="rounded-full px-2.5 py-1 font-semibold" style="background:' + color + '1a;color:' + color + '">' + esc(cat) + '</span></div>' +
              '<div class="mt-3 text-3xl">' + (p.emoji || "📝") + '</div>' +
              '<h3 class="mt-1 text-lg font-bold text-gray-900 dark:text-white">' + esc(p.title) + '</h3>' +
              '<p class="mt-2 flex-1 text-sm text-gray-600 dark:text-gray-400">' + excerpt(p.body) + '</p>' +
              '<div class="mt-4 flex items-center gap-2">' +
                '<img src="' + dice(p.author_name) + '" alt="" width="28" height="28" class="h-7 w-7 rounded-full bg-gray-100 dark:bg-white/10"/>' +
                '<span class="text-xs font-medium text-gray-700 dark:text-gray-300">' + esc(p.author_name || "Anonymous") + '</span>' +
                '<span class="text-xs text-gray-400">· ' + fmt(p.created_at) + '</span>' +
                '<button data-read="' + p.id + '" class="ml-auto text-sm font-semibold text-brand-600 hover:underline dark:text-brand-300">Read →</button>' +
              '</div>' +
            '</article>'
          );
        }).join("");
        listEl.querySelectorAll("[data-read]").forEach((b) => b.addEventListener("click", () => openReader(b.getAttribute("data-read"))));
        wireFilter();
      } catch (e) {
        loadingEl.classList.add("hidden"); emptyEl.classList.remove("hidden"); emptyEl.textContent = "Couldn't load posts.";
      }
    }

    function wireFilter() {
      const chips = document.querySelectorAll("#pf-filter .filter-chip");
      chips.forEach((chip) => chip.addEventListener("click", () => {
        chips.forEach((c) => c.classList.remove("active"));
        chip.classList.add("active");
        const f = chip.getAttribute("data-filter");
        listEl.querySelectorAll("article[data-cat]").forEach((a) => {
          a.style.display = (f === "all" || a.getAttribute("data-cat") === f) ? "" : "none";
        });
      }));
    }

    async function openReader(id) {
      const p = posts.find((x) => x.id === id);
      if (!p) return;
      listEl.classList.add("hidden");
      reader.classList.remove("hidden");
      const slug = "post:" + p.id;
      articleEl.innerHTML =
        '<p class="text-sm text-gray-400">By ' + esc(p.author_name || "Anonymous") + ' · ' + fmt(p.created_at) + '</p><h1>' + esc(p.title) + '</h1>' +
        (await render(p.body)) +
        '<div id="post-engage" class="not-prose mt-8"></div>';
      if (window.polyHighlight) window.polyHighlight(articleEl);
      window.scrollTo({ top: 0, behavior: "smooth" });
      if (live && window.PolyEngage) window.PolyEngage(document.getElementById("post-engage"), slug);
    }

    load();
  })();
</script>
