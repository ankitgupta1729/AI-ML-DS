---
import BaseLayout from "../layouts/BaseLayout.astro";
import { MEMBERS, COMMENTS, memberByHandle, avatarUrl, relativeTime } from "../lib/community";
import { getCollection } from "astro:content";

const posts = await getCollection("blog");
const titleFor = (id: string) => posts.find((p) => p.id === id)?.data.title;

const leaderboard = [...MEMBERS].sort((a, b) => b.contributions - a.contributions);
const activity = [...COMMENTS].sort(
  (a, b) => new Date(b.postedAt).valueOf() - new Date(a.postedAt).valueOf()
);
const totalComments = COMMENTS.reduce((n, c) => n + 1 + (c.replies?.length ?? 0), 0);
const totalLikes = COMMENTS.reduce(
  (n, c) => n + c.likes + (c.replies?.reduce((s, r) => s + r.likes, 0) ?? 0),
  0
);
---

<BaseLayout title="Community" description="Meet the curious minds discussing ideas on Polymath.">
  <section class="aurora">
    <div class="mx-auto max-w-6xl px-4 py-14 text-center sm:px-6">
      <h1 class="font-serif text-4xl font-bold text-gray-900 sm:text-5xl dark:text-white">The Community</h1>
      <p class="mx-auto mt-3 max-w-2xl text-lg text-gray-600 dark:text-gray-400">
        Polymath is built around conversation. Meet some of the curious minds who read, react, question and teach here.
      </p>
      <div class="mx-auto mt-3 inline-flex items-center gap-2 rounded-full bg-amber-100 px-3 py-1 text-xs font-semibold text-amber-700 dark:bg-amber-900/30 dark:text-amber-300">
        ✨ Sample community — demo data showcasing the discussion features
      </div>

      <div class="mx-auto mt-8 grid max-w-2xl grid-cols-3 gap-4">
        <div><div class="text-3xl font-extrabold text-gray-900 dark:text-white">{MEMBERS.length}</div><div class="text-sm text-gray-500">Members</div></div>
        <div><div class="text-3xl font-extrabold text-gray-900 dark:text-white">{totalComments}</div><div class="text-sm text-gray-500">Comments</div></div>
        <div><div class="text-3xl font-extrabold text-gray-900 dark:text-white">{totalLikes}</div><div class="text-sm text-gray-500">Reactions</div></div>
      </div>
    </div>
  </section>

  <!-- Live points leaderboard (real contributors) -->
  <section class="mx-auto max-w-3xl px-4 pt-12 sm:px-6">
    <div class="mb-5 flex items-center justify-between">
      <h2 class="font-serif text-2xl font-bold text-gray-900 dark:text-white">🏆 Leaderboard</h2>
      <span class="text-xs text-gray-400">Posts ×10 · Comments ×2 · Ideas ×3</span>
    </div>
    <div id="lb-skeleton" class="space-y-2">
      {[0, 1, 2].map(() => (
        <div class="flex items-center gap-3 rounded-xl border border-gray-200 p-3 dark:border-white/10">
          <div class="skeleton h-7 w-7 rounded-full"></div><div class="skeleton h-9 w-9 rounded-full"></div><div class="skeleton h-4 w-40"></div>
        </div>
      ))}
    </div>
    <ol id="lb-list" class="space-y-2"></ol>
    <p id="lb-empty" class="hidden rounded-2xl border border-dashed border-gray-300 p-8 text-center text-sm text-gray-500 dark:border-white/10">
      No points yet — publish an article, comment, or suggest an idea to climb the board!
    </p>

    <div class="mb-5 mt-12 flex items-center justify-between">
      <h2 class="font-serif text-2xl font-bold text-gray-900 dark:text-white">🧠 Top doubt-solvers</h2>
      <span class="text-xs text-gray-400">Answers ×3 · Upvotes ×1</span>
    </div>
    <ol id="ds-list" class="space-y-2"></ol>
    <p id="ds-empty" class="hidden rounded-2xl border border-dashed border-gray-300 p-8 text-center text-sm text-gray-500 dark:border-white/10">
      No answers yet — be the first to <a href="/doubts" class="font-semibold text-brand-600">solve a doubt</a> and top this board!
    </p>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
    <h2 class="mb-6 font-serif text-2xl font-bold text-gray-900 dark:text-white">Featured members <span class="align-middle text-xs font-normal text-amber-600">· sample</span></h2>
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        MEMBERS.map((m) => (
          <div data-reveal class="card-lift rounded-2xl border border-gray-200 bg-white p-5 dark:border-white/10 dark:bg-white/[0.03]">
            <div class="flex items-center gap-3">
              <img src={avatarUrl(m.handle)} alt={m.name} width="52" height="52" loading="lazy" class="h-13 w-13 rounded-full bg-gray-100 dark:bg-white/10" style="height:52px;width:52px" />
              <div>
                <p class="font-bold text-gray-900 dark:text-white">{m.name}</p>
                <p class="text-sm text-gray-400">@{m.handle}</p>
              </div>
            </div>
            <span class="mt-3 inline-block rounded-full bg-brand-50 px-2.5 py-1 text-xs font-medium text-brand-700 dark:bg-brand-900/30 dark:text-brand-300">{m.role}</span>
            <p class="mt-2 text-sm leading-relaxed text-gray-600 dark:text-gray-400">{m.bio}</p>
            <p class="mt-3 text-xs text-gray-400">{m.contributions} contributions · joined {new Date(m.joined).toLocaleDateString("en-US", { month: "short", year: "numeric" })}</p>
          </div>
        ))
      }
    </div>

    <div class="mt-14 grid gap-10 lg:grid-cols-2">
      <div>
        <h2 class="mb-5 font-serif text-2xl font-bold text-gray-900 dark:text-white">🏆 Top contributors</h2>
        <ol class="space-y-3">
          {
            leaderboard.slice(0, 6).map((m, i) => (
              <li class="flex items-center gap-3 rounded-xl border border-gray-200 bg-white p-3 dark:border-white/10 dark:bg-white/[0.03]">
                <span class="grid h-7 w-7 place-items-center rounded-full bg-brand-600 text-sm font-bold text-white">{i + 1}</span>
                <img src={avatarUrl(m.handle)} alt={m.name} width="36" height="36" loading="lazy" class="h-9 w-9 rounded-full bg-gray-100 dark:bg-white/10" />
                <span class="font-semibold text-gray-900 dark:text-white">{m.name}</span>
                <span class="ml-auto text-sm font-bold text-brand-600 dark:text-brand-300">{m.contributions}</span>
              </li>
            ))
          }
        </ol>
      </div>

      <div>
        <h2 class="mb-5 font-serif text-2xl font-bold text-gray-900 dark:text-white">🔔 Recent activity</h2>
        <ul class="space-y-3">
          {
            activity.slice(0, 7).map((c) => {
              const m = memberByHandle(c.handle);
              const t = c.article === "general" ? "the community wall" : titleFor(c.article);
              return (
                <li class="flex items-start gap-3 rounded-xl border border-gray-200 bg-white p-3 text-sm dark:border-white/10 dark:bg-white/[0.03]">
                  <img src={avatarUrl(c.handle)} alt={m?.name} width="32" height="32" loading="lazy" class="h-8 w-8 shrink-0 rounded-full bg-gray-100 dark:bg-white/10" />
                  <div>
                    <span class="font-semibold text-gray-900 dark:text-white">{m?.name}</span>
                    <span class="text-gray-500 dark:text-gray-400"> commented on </span>
                    {c.article === "general" ? (
                      <a href="/forum" class="font-medium text-brand-600 dark:text-brand-300">{t}</a>
                    ) : (
                      <a href={`/blog/${c.article}`} class="font-medium text-brand-600 dark:text-brand-300">{t}</a>
                    )}
                    <span class="text-gray-400"> · {relativeTime(c.postedAt)}</span>
                    <p class="mt-1 line-clamp-2 text-gray-600 dark:text-gray-400">“{c.body}”</p>
                  </div>
                </li>
              );
            })
          }
        </ul>
      </div>
    </div>

    <div class="mt-14 rounded-3xl border border-brand-200/50 bg-gradient-to-br from-brand-50 to-pink-50 p-8 text-center dark:border-white/10 dark:from-brand-900/30 dark:to-pink-900/20">
      <h2 class="font-serif text-2xl font-bold text-gray-900 dark:text-white">Join the conversation</h2>
      <p class="mx-auto mt-2 max-w-xl text-gray-700 dark:text-gray-300">Every article has reactions and comments, and the forum is open to everyone. No ads, no algorithm — just good discussion.</p>
      <div class="mt-5 flex flex-wrap justify-center gap-3">
        <a href="/forum" class="rounded-xl bg-brand-600 px-5 py-2.5 font-semibold text-white transition hover:bg-brand-700">Visit the forum</a>
        <a href="/blog" class="rounded-xl border border-gray-300 bg-white px-5 py-2.5 font-semibold text-gray-800 transition hover:border-brand-400 dark:border-white/15 dark:bg-white/5 dark:text-gray-100">Start reading</a>
      </div>
    </div>
  </section>

  <script is:inline>
    (function () {
      const skel = document.getElementById("lb-skeleton");
      const list = document.getElementById("lb-list");
      const empty = document.getElementById("lb-empty");
      if (!list) return;
      const esc = (s) => (s || "").replace(/[&<>"']/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[c]));
      const medal = (i) => ["🥇", "🥈", "🥉"][i] || (i + 1);
      (async () => {
        let rows = [];
        try {
          if (window.polyDB) {
            const sb = await window.polyDB();
            if (sb) { const { data } = await sb.rpc("leaderboard"); rows = (data || []).filter((r) => r.points > 0); }
          }
        } catch (e) {}
        skel.classList.add("hidden");
        if (!rows.length) { empty.classList.remove("hidden"); return; }
        list.innerHTML = rows.map((r, i) =>
          '<li class="flex items-center gap-3 rounded-xl border border-gray-200 bg-white p-3 dark:border-white/10 dark:bg-white/[0.03]">' +
            '<span class="grid h-7 w-7 place-items-center text-sm font-bold">' + medal(i) + '</span>' +
            '<img src="' + (r.avatar_url || ("https://api.dicebear.com/9.x/thumbs/svg?seed=" + encodeURIComponent(r.name || "user"))) + '" alt="" width="36" height="36" class="h-9 w-9 rounded-full bg-gray-100 dark:bg-white/10"/>' +
            '<a href="/profile?id=' + r.id + '" class="font-semibold text-gray-900 hover:text-brand-600 dark:text-white">' + esc(r.name || "Anonymous") + '</a>' +
            '<span class="ml-auto rounded-full bg-brand-50 px-2.5 py-1 text-sm font-bold text-brand-700 dark:bg-brand-900/30 dark:text-brand-300">' + r.points + ' pts</span>' +
          '</li>'
        ).join("");
      })();

      // Top doubt-solvers (computed from answers + accepted answers + votes)
      (async () => {
        const dsList = document.getElementById("ds-list");
        const dsEmpty = document.getElementById("ds-empty");
        if (!dsList || !window.polyDB) return;
        try {
          const sb = await window.polyDB();
          if (!sb) return;
          const { data: ans } = await sb.from("answers").select("author_id, author_name, votes");
          if (!ans || !ans.length) { dsEmpty.classList.remove("hidden"); return; }
          const by = {};
          ans.forEach((a) => {
            const k = a.author_id || ("name:" + (a.author_name || "Anonymous"));
            by[k] = by[k] || { id: a.author_id, name: a.author_name || "Anonymous", answers: 0, votes: 0 };
            by[k].answers++; by[k].votes += a.votes || 0;
          });
          const ranked = Object.values(by).map((u) => ({ ...u, score: u.answers * 3 + u.votes })).sort((a, b) => b.score - a.score).slice(0, 10);
          if (!ranked.length) { dsEmpty.classList.remove("hidden"); return; }
          dsList.innerHTML = ranked.map((r, i) =>
            '<li class="flex items-center gap-3 rounded-xl border border-gray-200 bg-white p-3 dark:border-white/10 dark:bg-white/[0.03]">' +
              '<span class="grid h-7 w-7 place-items-center text-sm font-bold">' + medal(i) + '</span>' +
              '<img src="https://api.dicebear.com/9.x/thumbs/svg?seed=' + encodeURIComponent(r.name) + '&radius=50" width="36" height="36" class="h-9 w-9 rounded-full bg-gray-100 dark:bg-white/10"/>' +
              (r.id ? '<a href="/profile?id=' + r.id + '" class="font-semibold text-gray-900 hover:text-brand-600 dark:text-white">' + esc(r.name) + '</a>' : '<span class="font-semibold text-gray-900 dark:text-white">' + esc(r.name) + '</span>') +
              '<span class="ml-auto text-xs text-gray-400">' + r.answers + ' ans · ' + r.votes + ' votes</span>' +
              '<span class="rounded-full bg-green-50 px-2.5 py-1 text-sm font-bold text-green-700 dark:bg-green-900/30 dark:text-green-300">' + r.score + '</span>' +
            '</li>'
          ).join("");
        } catch (e) { dsEmpty.classList.remove("hidden"); }
      })();
    })();
  </script>
</BaseLayout>
