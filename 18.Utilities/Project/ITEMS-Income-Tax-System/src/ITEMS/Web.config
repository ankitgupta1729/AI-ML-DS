<?xml version="1.0" encoding="utf-8"?>
<!--
  ITEMS · Income Tax Evaluation & Maintenance System
  ASP.NET Web Forms (VB.NET) + Oracle (ODP.NET Managed)
  Edit the connection string below to point at your Oracle service, then run
  the scripts in /database before starting the app.
-->
<configuration>
  <configSections>
    <!-- Version must match the installed Oracle.ManagedDataAccess (21.13.0 => 4.122.21.0) -->
    <section name="oracle.manageddataaccess.client"
             type="OracleInternal.Common.ODPMSectionHandler, Oracle.ManagedDataAccess, Version=4.122.21.0, Culture=neutral, PublicKeyToken=89b483f429c47342" />
  </configSections>

  <connectionStrings>
    <!-- Local Oracle XE / on-prem -->
    <add name="ItemsDb"
         connectionString="User Id=ITEMS;Password=Items#2025;Data Source=localhost:1521/XEPDB1;"
         providerName="Oracle.ManagedDataAccess.Client" />
    <!-- Oracle Autonomous DB (Always Free) example — use a wallet or the
         easy-connect string from OCI; set TNS_ADMIN to the wallet folder:
      connectionString="User Id=ITEMS;Password=Items#2025;Data Source=itemsdb_high;" -->
  </connectionStrings>

  <appSettings>
    <add key="AppName" value="Income Tax Evaluation System" />
    <add key="AssessmentYearDefaultFrom" value="2024-04-01" />
    <add key="AssessmentYearDefaultTo" value="2025-03-31" />
  </appSettings>

  <system.web>
    <compilation debug="true" strict="true" explicit="true" targetFramework="4.8" />
    <httpRuntime targetFramework="4.8" enableVersionHeader="false" />
    <pages>
      <namespaces>
        <add namespace="System" />
        <add namespace="System.Web" />
        <add namespace="ITEMS" />
      </namespaces>
    </pages>
    <!-- Forms authentication protects every module (SRS §7 security) -->
    <authentication mode="Forms">
      <forms loginUrl="~/Login.aspx" timeout="30" slidingExpiration="true" cookieless="UseCookies" />
    </authentication>
    <authorization>
      <deny users="?" />
    </authorization>
    <sessionState mode="InProc" timeout="30" />
    <customErrors mode="RemoteOnly" defaultRedirect="~/Error.aspx" />
  </system.web>

  <location path="Login.aspx">
    <system.web>
      <authorization><allow users="*" /></authorization>
    </system.web>
  </location>
  <location path="Content">
    <system.web>
      <authorization><allow users="*" /></authorization>
    </system.web>
  </location>

  <oracle.manageddataaccess.client>
    <version number="*">
      <settings>
        <setting name="TraceLevel" value="0" />
      </settings>
    </version>
  </oracle.manageddataaccess.client>

  <system.webServer>
    <httpProtocol>
      <customHeaders>
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="X-Frame-Options" value="SAMEORIGIN" />
      </customHeaders>
    </httpProtocol>
  </system.webServer>
</configuration>
